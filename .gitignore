# Ephemeral agent reports (not source, not docs-for-humans)
team-reports/
!team-reports/README.md
museum-backend/reports/
new.md

# Xcode SPM user state (keep Package.resolved tracked)
xcshareddata/swiftpm/configuration/

# Claude Code session lock (ephemeral, per-PID)
.claude/scheduled_tasks.lock

# Quality hooks ephemeral cache (bg-runner output + alerts log)
.claude/.cache/

# Agent worktrees (ephemeral isolated workspaces from Agent isolation:"worktree")
.claude/worktrees/

# Perf seed checkpoint (local state, not for VCS)
museum-backend/.perf-seed-checkpoint.json

# C3 (2026-05) — visual-similarity ONNX bundles. Binary, ~340MB; fetched at
# Docker build time by museum-backend/scripts/fetch-models.sh. Never committed.
museum-backend/models/
**/*.onnx

# W3 (T5.5) — printable QR-cartel PDFs. Regenerable from fixtures/*.csv via
# scripts/generate-qr-cartels.cjs; binaries, not source.
museum-backend/cartels-*.pdf

# Local pnpm content-addressable store (created by `pnpm install --prefer-offline`
# in some env setups). Never source-tracked.
.pnpm-store/
