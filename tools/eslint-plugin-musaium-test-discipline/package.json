  },
  "peerDependencies": {
    "eslint": ">=8 <11"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.58.1",
    "@typescript-eslint/rule-tester": "^8.58.1",
    "@typescript-eslint/utils": "^8.58.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.0"
  }
}
