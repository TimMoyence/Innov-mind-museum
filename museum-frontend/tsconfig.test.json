{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": ["node"],
    "jsx": "react-jsx",
    "noEmit": false
  },
  "include": [
    "tests/**/*.ts",
    "features/chat/domain/contracts.ts",
    "features/settings/runtimeSettings.pure.ts",
    "shared/lib/errors.ts",
    "shared/types/AppError.ts"
  ]
}
