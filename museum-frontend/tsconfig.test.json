{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": ["node"],
    "jsx": "react-jsx",
    "noEmit": false
  },
  "include": [
