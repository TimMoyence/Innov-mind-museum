# Musaium mobile frontend - preview / preprod (.env.preview.example)
# Used for EAS preview builds (preprod = staging)

# Usually leave empty for preview builds to force variant-specific URL resolution.
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_ENVIRONMENT=staging

EXPO_PUBLIC_API_BASE_URL_STAGING=https://staging-api.example.com
EXPO_PUBLIC_API_BASE_URL_PROD=https://api.example.com

APP_VARIANT=preview

# Cert pinning — ON in preview to validate pinset behaviour pre-store-submission.
# Toggle to false only when targeting a non-pinned local backend.
EXPO_PUBLIC_CERT_PINNING_ENABLED=true
