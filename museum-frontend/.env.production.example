# Musaium mobile frontend - production (.env.production.example)
# Used for EAS production builds

# Usually leave empty for production builds to avoid accidental override.
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_ENVIRONMENT=production

EXPO_PUBLIC_API_BASE_URL_STAGING=https://staging-api.example.com
EXPO_PUBLIC_API_BASE_URL_PROD=https://api.example.com

APP_VARIANT=production

# Cert pinning — must be ON in production. See shared/config/cert-pinning.ts
# + museum-frontend/docs/CERT_PINNING_RUNBOOK.md for the pinset + rotation runbook.
EXPO_PUBLIC_CERT_PINNING_ENABLED=true

# Plausible funnel analytics (KR4) — set both to enable funnel tracking in prod.
# Injected at EAS build time. See docs/CI_CD_SECRETS.md (Secrets Mobile / Expo / EAS).
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=REPLACE_ME
EXPO_PUBLIC_PLAUSIBLE_ENDPOINT_URL=REPLACE_ME   # e.g. https://plausible.example/api/event
