# Deprecated convenience template.
# Prefer environment-specific templates:
#   cp .env.local.example .env
#   cp .env.preview.example .env
#   cp .env.production.example .env

EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL_STAGING=https://staging-api.example.com
EXPO_PUBLIC_API_BASE_URL_PROD=https://api.example.com
EXPO_PUBLIC_API_ENVIRONMENT=staging
APP_VARIANT=development

# EAS project ID — used by expo-updates for OTA update URLs.
# Set this if you use EAS Update. Otherwise the projectId from app.json is used.
# See docs/CI_CD_SECRETS.md for details.
# EXPO_PUBLIC_EAS_PROJECT_ID=

# Chat SSE streaming (default off — see .env.local.example).
EXPO_PUBLIC_CHAT_STREAMING=false

# Cert pinning — OFF for local dev (default API base = localhost:3000, no TLS).
# Set to true ONLY when pointing local builds at https://musaium.com to test pinning.
EXPO_PUBLIC_CERT_PINNING_ENABLED=false
