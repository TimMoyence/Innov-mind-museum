# Set by expo-router. This enables Fabric-only features from react-native-screens
ENV['RNS_GAMMA_ENABLED'] ||= '1'
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']

  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_HERMES_V1_ENABLED'] ||= '1' if podfile_properties['expo.useHermesV1'] == 'true'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'Musaium' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # @musaium/maplibre-spm-integration
    # Wire the MapLibre Swift Package Manager dep into both the MapLibreReactNative
    # target and every user target (Musaium.app). Without this call the `MapLibre`
    # headers (`MapLibre/MapLibre.h`, `MapLibre/MLNNetworkConfiguration.h`) are not
    # resolved and the build fails. See MapLibreReactNative.podspec for `$MLRN`.
    $MLRN.post_install(installer) if defined?($MLRN)

    # @musaium/fmt-consteval-patch
    # Fix fmt consteval errors with Xcode 26+ Apple Clang regression.
    # Widen the Apple Clang guard to disable consteval on all versions.
    fmt_base = File.join(__dir__, 'Pods', 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      patched = content.sub(
        'defined(__apple_build_version__) && __apple_build_version__ < 14000029L',
        'defined(__apple_build_version__)'
      )
      if patched != content
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
      end
    end

    # @musaium/maplibre-dedup-signature
    # Workaround: @maplibre/maplibre-react-native's post_install adds MapLibre
    # SPM to BOTH the MapLibreReactNative pod target AND every user target
    # (Musaium.app). Each produces its own MapLibre.xcframework-ios.signature
    # under Release-iphoneos/, then the Archive "Copy Signatures" phase
    # fails with NSCocoaErrorDomain 516 (file already exists). Remove the
    # redundant signature from the pod's BUILT_PRODUCTS_DIR as the final
    # build phase so Archive only sees the app-target copy.
    mlrn_target = installer.pods_project.targets.find { |t| t.name == 'MapLibreReactNative' }
    if mlrn_target
      mlrn_phase_name = '[Musaium] Remove duplicate MapLibre signature'
      already_patched = mlrn_target.build_phases.any? do |p|
        p.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase) && p.name == mlrn_phase_name
      end
      unless already_patched
        phase = mlrn_target.new_shell_script_build_phase(mlrn_phase_name)
        phase.shell_script = %(rm -f "${BUILT_PRODUCTS_DIR}/MapLibre.xcframework-ios.signature"\n)
        installer.pods_project.save
      end
    end

    # @musaium/expo-updates-entry-file
    # Workaround for expo-updates 55.0.18 + Metro: @expo/config strips `.js`
    # from the resolved entry path (paths.js:227), then Metro's resolver 404s
    # on `node_modules/expo-router/entry` during the "Generate updates
    # resources" script phase. Forcing ENTRY_FILE with the explicit extension
    # short-circuits resolveRelativeEntryPoint in createManifestForBuildAsync.
    exu_target = installer.pods_project.targets.find { |t| t.name == 'EXUpdates' }
    if exu_target
      exu_inject = %(export ENTRY_FILE="node_modules/expo-router/entry.js"\n)
      patched_phase = false
      exu_target.build_phases.each do |phase|
        next unless phase.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
        next unless phase.name&.include?('Generate updates resources')
        next if phase.shell_script.start_with?(exu_inject)
        phase.shell_script = exu_inject + phase.shell_script
        patched_phase = true
      end
      installer.pods_project.save if patched_phase
    end
  end
end
