{
  "name": "musaium-mobile",
  "main": "expo-router/entry",
  "version": "1.0.5",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "build:web": "expo export --platform web",
    "generate:openapi-types": "openapi-typescript ../museum-backend/openapi/openapi.json -o shared/api/generated/openapi.ts && prettier --write shared/api/generated/openapi.ts",
    "check:openapi-types": "npm run generate:openapi-types && git diff --exit-code -- shared/api/generated/openapi.ts",
    "check:i18n": "node scripts/check-i18n-completeness.js",
    "lint": "eslint . --max-warnings=22 && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:node && npm run test:rn",
    "test:node": "rm -rf .test-dist && tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "test:rn": "jest",
    "test:coverage": "jest --coverage",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@maplibre/maplibre-react-native": "11.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.0.14",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "@sentry/react-native": "^8.7.0",
    "@shopify/flash-list": "2.3.1",
    "axios": "^1.15.1",
    "babel-preset-expo": "~55.0.8",
    "expo": "^55.0.11",
    "expo-apple-authentication": "~55.0.11",
    "expo-asset": "~55.0.12",
    "expo-audio": "^55.0.11",
    "expo-blur": "~55.0.12",
    "expo-build-properties": "~55.0.11",
    "expo-camera": "~55.0.13",
    "expo-clipboard": "~55.0.11",
    "expo-constants": "~55.0.14",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.12",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.16",
    "expo-linear-gradient": "~55.0.11",
    "expo-linking": "~55.0.11",
    "expo-local-authentication": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-location": "~55.1.6",
    "expo-router": "~55.0.10",
    "expo-secure-store": "~55.0.11",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-store-review": "~55.0.13",
    "expo-system-ui": "~55.0.15",
    "expo-updates": "~55.0.18",
    "i18next": "^25.8.20",
    "intl-pluralrules": "^2.0.1",
    "js-sha256": "^0.11.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.31.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^10.4.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "expo-dev-client": "~55.0.22",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.13",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.1"
  },
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native",
        "expo",
        "expo-apple-authentication",
        "expo-asset",
        "expo-audio",
        "expo-blur",
        "expo-build-properties",
        "expo-camera",
        "expo-clipboard",
        "expo-constants",
        "expo-dev-client",
        "expo-file-system",
        "expo-haptics",
        "expo-image-manipulator",
        "expo-image-picker",
        "expo-linear-gradient",
        "expo-linking",
        "expo-local-authentication",
        "expo-localization",
        "expo-location",
        "expo-router",
        "expo-secure-store",
        "expo-splash-screen",
        "expo-store-review",
        "expo-system-ui",
        "expo-updates",
        "jest-expo",
        "react-native-gesture-handler",
        "react-native-safe-area-context",
        "react-native-screens"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": []
      }
    }
  },
  "overrides": {
    "markdown-it": ">=14.0.0",
    "follow-redirects": ">=1.15.12",
    "@tootallnate/once": ">=2.0.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
