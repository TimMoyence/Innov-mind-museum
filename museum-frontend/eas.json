{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_API_ENVIRONMENT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_ENVIRONMENT": "staging",
        "ENTRY_FILE": "node_modules/expo-router/entry.js"
      }
    },
    "internal": {
      "extends": "production",
      "channel": "internal",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_ENVIRONMENT": "staging"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_ENVIRONMENT": "production",
        "EXPO_PUBLIC_PLAUSIBLE_DOMAIN": "musaium.com",
        "ENTRY_FILE": "node_modules/expo-router/entry.js"
      },
      "android": {
        "env": {
          "SENTRY_PROJECT": "android",
          "EXPO_PUBLIC_SENTRY_DSN_ANDROID": "https://db0002a004fb7cfb40c915fdcc1f4469@o4511082055860224.ingest.de.sentry.io/4511082080370768"
        }
      },
      "ios": {
        "env": {
          "SENTRY_PROJECT": "apple-ios",
          "EXPO_PUBLIC_SENTRY_DSN_IOS": "https://50bc059a7310d9b37c4c3f3f20a64f3d@o4511082055860224.ingest.de.sentry.io/4511082083057744"
        }
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./.secrets/google-service-account.json",
        "track": "internal",
        "releaseStatus": "completed"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "$ASC_APP_ID",
        "appleId": "$APPLE_ID",
        "appleTeamId": "$APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./.secrets/google-service-account.json",
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}
