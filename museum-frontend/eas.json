{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_API_ENVIRONMENT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_ENVIRONMENT": "staging"
      }
    },
    "internal": {
      "extends": "production",
      "channel": "internal",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_ENVIRONMENT": "staging"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_ENVIRONMENT": "production"
      },
      "android": {
        "env": {
          "SENTRY_PROJECT": "android"
        }
      },
      "ios": {
        "env": {
          "SENTRY_PROJECT": "apple-ios"
        }
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./.secrets/google-service-account.json",
        "track": "internal",
        "releaseStatus": "completed"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "$ASC_APP_ID",
        "appleId": "$APPLE_ID",
        "appleTeamId": "$APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./.secrets/google-service-account.json",
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}
