# Musaium mobile frontend - local development (.env.local.example)
# Usage: cp .env.local.example .env
# local = dev machine

# Optional local override (used first if set)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Build-variant URLs (kept here so preview/prod builds are testable from local CLI)
EXPO_PUBLIC_API_BASE_URL_STAGING=https://staging-api.example.com
EXPO_PUBLIC_API_BASE_URL_PROD=https://api.example.com
EXPO_PUBLIC_API_ENVIRONMENT=staging

# Expo/EAS project ID is written by `eas project:init` into app.json.
# Keep app.json as the single source of truth and do not duplicate it here.

# Local helper only (app.config.ts also derives from EAS_BUILD_PROFILE)
APP_VARIANT=development
