{
  "name": "@musaium/shared",
  "version": "0.2.0",
  "private": true,
  "description": "Cross-app sentry scrubber + observability primitives — consumed by museum-backend, museum-web, and museum-frontend.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "default": "./dist/observability/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "node --experimental-strip-types --no-warnings --test src/observability/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
