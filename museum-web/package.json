{
  "name": "museum-web",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "generate:openapi-types": "openapi-typescript ../museum-backend/openapi/openapi.json -o src/lib/api/generated/openapi.ts && prettier --write src/lib/api/generated/openapi.ts",
    "check:openapi-types": "pnpm generate:openapi-types && git diff --exit-code -- src/lib/api/generated/openapi.ts",
    "lint": "eslint src/ && tsc --noEmit",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.49.0",
    "framer-motion": "^12.38.0",
    "maplibre-gl": "^5.23.0",
    "next": "^15.5.15",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.5.15",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "pg": "^8.13.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1": ">=1.1.12 <2",
      "brace-expansion@2": ">=2.0.2 <3",
      "protocol-buffers-schema": ">=3.6.1",
      "postcss": ">=8.5.10"
    }
  }
}
