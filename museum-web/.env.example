# Backend API URL (used by rewrites in dev, and by server components)
API_BASE_URL=http://localhost:3000

# Public-facing base URL (for OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://musaium.com

# Default locale (fr or en)
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Sentry error tracking (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
