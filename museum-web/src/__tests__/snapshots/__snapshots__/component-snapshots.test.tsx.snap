// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Button snapshots > outline variant matches snapshot 1`] = `"<button class="inline-flex items-center justify-center font-medium transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 disabled:pointer-events-none disabled:opacity-50 border border-primary-300 text-primary-600 hover:bg-primary-50 active:bg-primary-100 px-7 py-3 text-lg rounded-xl ">Large Outline</button>"`;

exports[`Button snapshots > primary variant matches snapshot 1`] = `"<button class="inline-flex items-center justify-center font-medium transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 disabled:pointer-events-none disabled:opacity-50 bg-primary-500 text-white hover:bg-primary-600 active:bg-primary-700 shadow-sm px-5 py-2.5 text-base rounded-lg ">Primary</button>"`;

exports[`Button snapshots > secondary variant matches snapshot 1`] = `"<button class="inline-flex items-center justify-center font-medium transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500 disabled:pointer-events-none disabled:opacity-50 bg-primary-100 text-primary-700 hover:bg-primary-200 active:bg-primary-300 px-3 py-1.5 text-sm rounded-md ">Small Secondary</button>"`;

exports[`FeatureCard snapshots > matches snapshot with icon, title, and description 1`] = `"<div class="liquid-glass-card group p-6 sm:p-8"><div class="relative flex h-12 w-12 items-center justify-center rounded-xl text-primary-500 shadow-sm transition-all duration-300 group-hover:shadow-md" style="background: rgba(255, 255, 255, 0.6); backdrop-filter: blur(12px) saturate(1.4); border: 1px solid rgba(255, 255, 255, 0.4);"><span data-testid="icon">IC</span></div><h3 class="mt-4 text-lg font-semibold text-text-primary">AI Recognition</h3><p class="mt-2 text-sm leading-relaxed text-text-secondary">Point your camera at any artwork</p></div>"`;

exports[`Footer snapshots > matches snapshot with links and copyright 1`] = `"<footer class="border-t border-primary-100/50 bg-white/50 backdrop-blur-sm"><div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8"><div class="flex flex-col items-center gap-4 text-center sm:flex-row sm:justify-between sm:text-left"><div class="flex items-center gap-3"><img alt="Musaium" width="28" height="28" class="rounded-md" src="/images/logo.png"><div class="space-y-0.5"><p class="text-sm text-text-secondary">(c) 2025 Musaium</p><p class="text-xs text-text-muted">Made by InnovMind</p></div></div><nav class="flex gap-6" aria-label="Footer"><a href="/en/privacy" class="text-sm text-text-secondary transition-colors hover:text-primary-600">Privacy Policy</a><a href="/en/support" class="text-sm text-text-secondary transition-colors hover:text-primary-600">Help</a></nav></div></div></footer>"`;

exports[`Header snapshots > matches snapshot with nav links 1`] = `"<header class="sticky top-0 z-50" style="background-color: rgba(255, 255, 255, 0); border-bottom: rgba(255, 255, 255, 0); backdrop-filter: blur(0px);"><div class="relative mx-auto flex max-w-7xl items-center justify-between px-4 py-2.5 sm:px-6 lg:px-8"><a href="/en" class="flex items-center gap-2.5 transition-opacity hover:opacity-80"><img alt="Musaium" width="36" height="36" class="rounded-lg" src="/images/logo.png"><span class="text-lg font-semibold tracking-tight text-text-primary">Musaium</span></a><nav class="hidden items-center gap-6 md:flex" aria-label="Main"><a href="/en" class="text-sm font-medium text-text-secondary transition-colors hover:text-primary-600">Home</a><a href="/en/support" class="text-sm font-medium text-text-secondary transition-colors hover:text-primary-600">Support</a><a href="/en/privacy" class="text-sm font-medium text-text-secondary transition-colors hover:text-primary-600">Privacy</a><a href="/fr" class="rounded-md px-3 py-1.5 text-sm font-medium text-primary-600 transition-colors hover:bg-primary-50" aria-label="Switch to French">EN</a><a href="/en#download" class="rounded-xl bg-primary-500 px-5 py-2 text-sm font-medium text-white shadow-sm transition-all hover:bg-primary-600 hover:shadow-md active:scale-[0.98]">Download</a></nav><button type="button" class="inline-flex items-center justify-center rounded-lg p-2 text-text-secondary transition-colors hover:bg-white/50 md:hidden" aria-label="Toggle menu" aria-expanded="false"><svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"></path></svg></button></div></header>"`;

exports[`StoreButton snapshots > Apple store variant matches snapshot 1`] = `"<a href="#" class="group relative inline-flex items-center gap-3 overflow-hidden rounded-2xl px-7 py-4 text-white transition-all duration-300 hover:shadow-xl active:scale-[0.98]" style="background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(20px) saturate(1.4); border: 1px solid var(--fn-dark-glass-border); box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.08);"><span class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100" style="background: linear-gradient(135deg, rgba(37, 99, 235, 0.15) 0%, rgba(56, 189, 248, 0.08) 100%);" aria-hidden="true"></span><span class="relative z-10"><svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path></svg></span><span class="relative z-10 text-left"><span class="block text-[10px] uppercase leading-tight opacity-70">Download on the</span><span class="block text-base font-semibold leading-tight">App Store</span></span></a>"`;

exports[`StoreButton snapshots > Google Play variant matches snapshot 1`] = `"<a href="#" class="group relative inline-flex items-center gap-3 overflow-hidden rounded-2xl px-7 py-4 text-white transition-all duration-300 hover:shadow-xl active:scale-[0.98]" style="background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(20px) saturate(1.4); border: 1px solid var(--fn-dark-glass-border); box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.08);"><span class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100" style="background: linear-gradient(135deg, rgba(37, 99, 235, 0.15) 0%, rgba(56, 189, 248, 0.08) 100%);" aria-hidden="true"></span><span class="relative z-10"><svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.405l2.937 1.697c.552.32.552 1.103 0 1.422l-2.937 1.697-2.535-2.535 2.535-2.281zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"></path></svg></span><span class="relative z-10 text-left"><span class="block text-[10px] uppercase leading-tight opacity-70">Get it on</span><span class="block text-base font-semibold leading-tight">Google Play</span></span></a>"`;
