{
  "title": "Guardrail Fairness (per-locale × layer)",
  "uid": "guardrail-fairness",
  "tags": ["musaium", "guardrail", "fairness", "ai-act", "art-10", "w6.10", "w4"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "musaium-prometheus"
        },
        "hide": 0
      },
      {
        "name": "locale",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(musaium_guardrail_decisions_total, locale)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "hide": 0
      },
      {
        "name": "layer",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(musaium_guardrail_decisions_total, layer)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Block rate — overall + per-locale",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Overall block rate (last 1h)",
      "description": "sum(rate(decisions{decision=\"block\"})) / sum(rate(decisions)). Reference value for AI Act Art. 10 compliance evidence kit. Expect 1-5% in normal traffic; > 10% suggests over-blocking (cf. promptfoo smoke alert).",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(musaium_guardrail_decisions_total{decision=\"block\"}[1h])) / clamp_min(sum(rate(musaium_guardrail_decisions_total[1h])), 1e-9)",
          "legendFormat": "overall"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Block rate over time — per locale",
      "description": "avg(rate(decisions{decision=\"block\",locale=$l}[1h]) / rate(decisions{locale=$l}[1h])) by (locale). FAIRNESS_METRICS_PLAN.md Phase 1 query. Highlights locales where the guardrail is disproportionately blocking — possible bias.",
      "datasource": "${datasource}",
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(musaium_guardrail_decisions_total{decision=\"block\",locale=~\"$locale\"}[1h])) by (locale) / clamp_min(sum(rate(musaium_guardrail_decisions_total{locale=~\"$locale\"}[1h])) by (locale), 1e-9)",
          "legendFormat": "{{ locale }}"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Per-layer breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Block rate — per layer (v1-keyword / v2-judge / v2-llm-guard / output / structural)",
      "description": "Which layer is doing the blocking? v1 high vs v2 high tells us very different remediation paths (regex tightening vs LLM judge tuning).",
      "datasource": "${datasource}",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(musaium_guardrail_decisions_total{decision=\"block\",layer=~\"$layer\"}[1h])) by (layer) / clamp_min(sum(rate(musaium_guardrail_decisions_total{layer=~\"$layer\"}[1h])) by (layer), 1e-9)",
          "legendFormat": "{{ layer }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "heatmap",
      "title": "Block rate heatmap — locale × layer (last 7d)",
      "description": "2-D view: rows = locale, cols = layer. Cells that pop indicate (locale, layer) pairs where blocking is concentrated.",
      "datasource": "${datasource}",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      },
      "options": {
        "calculate": false
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(musaium_guardrail_decisions_total{decision=\"block\"}[1h])) by (locale, layer) / clamp_min(sum(rate(musaium_guardrail_decisions_total[1h])) by (locale, layer), 1e-9)",
          "legendFormat": "{{ locale }} / {{ layer }}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "FPR proxy + per-category",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "FPR estimate — promptfoo smoke recall delta",
      "description": "Best available *proxy* for false-positive rate in production. The promptfoo daily smoke (llm-promptfoo-smoke.yml) runs 10 non-adversarial reference prompts daily; pass rate captured as guardrail_smoke_pass_rate. A drop below 80% means the guardrail is over-blocking legitimate art questions. Not a true FPR — labelled prod data is the only source for that. Tracked as TD-45.",
      "datasource": "${datasource}",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 21 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.80 },
              { "color": "green", "value": 0.90 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["mean", "min"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "musaium_guardrail_smoke_pass_rate",
          "legendFormat": "promptfoo smoke pass rate"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Block rate — per category × locale (top 10)",
      "description": "Diagnoses *why* a locale is over-blocked. If 'fr' is at 12% block-rate and the category panel shows 'insult' at 11% within fr, the insult regex is hot for fr. If it shows balanced across categories, the issue is upstream of category-classification.",
      "datasource": "${datasource}",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 30 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum(rate(musaium_guardrail_category_blocks_total{locale=~\"$locale\"}[1h])) by (locale, category))",
          "legendFormat": "{{ locale }} / {{ category }}"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Decisions volume / 1h (per locale)",
      "description": "Same period as the block rate panel. A locale with very low decision volume (< 50 / h) should be ignored in the block rate panel — small denominator inflates noise.",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 39 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(musaium_guardrail_decisions_total[1h])) by (locale)",
          "legendFormat": "{{ locale }}"
        }
      ]
    }
  ]
}
