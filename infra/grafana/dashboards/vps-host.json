{
  "title": "VPS Host",
  "uid": "musaium-vps-host",
  "tags": ["musaium", "infra", "vps", "node-exporter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "musaium-prometheus"
        },
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": "${datasource}",
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "titleFormat": "Deploy",
        "target": {
          "expr": "changes(process_start_time_seconds{service=\"musaium-backend\"}[1m]) > 0",
          "refId": "Anno"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "/ partition usage",
      "description": "Root filesystem usage percentage. Alert VPSDiskHigh fires at >80% (10m), VPSDiskCritical at >90% (5m). Auto-rollback engages at 100% — by then it is already too late.",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} * 100)",
          "legendFormat": "/"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory used",
      "description": "Memory pressure (1 - MemAvailable / MemTotal). Alert VPSMemoryHigh fires at >90% (10m). llm-guard has a 2G cap; backend uncapped — kernel OOM picks the biggest RSS.",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "mem"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU non-idle (5m avg)",
      "description": "CPU busy percentage averaged across cores over 5m. Alert VPSCPUHigh fires at >85% sustained 15m. Typical causes: enrichment worker hot loop, vacuum window, deploy regression.",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "cpu busy"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Load average (1m)",
      "description": "Linux load-average over 1 minute. Compared to logical CPU count by the threshold colors (>1.0 × cores = saturation).",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_load1",
          "legendFormat": "load1"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU usage by mode",
      "description": "Per-mode CPU breakdown (user / system / iowait / softirq / idle). Spikes in iowait point to disk bottleneck; sustained system high points to syscall storm (often a deploy regression).",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{mode!=\"idle\"}[5m]))",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Network throughput",
      "description": "Per-interface RX/TX bytes per second. Excludes virtual interfaces (lo, docker0, br-*, veth*). Watch for sustained saturation on the public NIC.",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[5m])",
          "legendFormat": "RX {{device}}"
        },
        {
          "refId": "B",
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[5m])",
          "legendFormat": "TX {{device}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Disk I/O operations (per device)",
      "description": "Read/write ops per second. Sustained high write IOPS often = postgres vacuum window or knowledge-extraction batch. Pair with the iowait line on the CPU panel.",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "iops" } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_disk_reads_completed_total{device!~\"loop.*|dm-.*\"}[5m])",
          "legendFormat": "read {{device}}"
        },
        {
          "refId": "B",
          "expr": "rate(node_disk_writes_completed_total{device!~\"loop.*|dm-.*\"}[5m])",
          "legendFormat": "write {{device}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "/ partition usage over time",
      "description": "Historical view of root partition fill. Use to project days-until-full and decide whether a cleanup-only fix is sufficient or a volume resize is needed.",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} * 100)",
          "legendFormat": "/ used %"
        }
      ]
    }
  ]
}
