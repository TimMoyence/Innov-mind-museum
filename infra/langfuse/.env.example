# Langfuse self-host — local dev. Generate strong values for prod.
# All three secrets MUST be set or the container exits.
#
# Generate:
#   openssl rand -hex 32   # NEXTAUTH_SECRET
#   openssl rand -hex 16   # SALT
#   openssl rand -hex 32   # ENCRYPTION_KEY (must be hex, exactly 32 bytes / 64 chars)
#   openssl rand -base64 24 # LANGFUSE_DB_PASSWORD (any password, dev only)

NEXTAUTH_SECRET=replace-me
SALT=replace-me
ENCRYPTION_KEY=replace-me-64-hex-chars
LANGFUSE_DB_PASSWORD=langfuse_dev_only
