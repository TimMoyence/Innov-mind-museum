# Host-side overrides applied by scripts/with-host-env.sh.
# Used when running migration:* / catalog-ingest / smoke commands FROM THE HOST
# (outside the Docker network). Container-internal vars (DB_HOST=db, DB_PORT=5432)
# stay in .env so the dev-backend container keeps working.
#
# Usage: pnpm migration:generate:host -- --name=Foo
# Or:    bash scripts/with-host-env.sh node scripts/catalog-ingest.ts ...
DB_HOST=localhost
DB_PORT=5433
