# Musaium backend - production (.env.production.example)
# Usage on production server: cp .env.production.example .env

NODE_ENV=production
PORT=3000
TRUST_PROXY=true
APP_VERSION=1.0.0
COMMIT_SHA=replace-at-deploy-time

# REQUIRED: only real public origins for mobile/web surfaces
CORS_ORIGINS=https://api.example.com,https://app.example.com
JSON_BODY_LIMIT=5mb
REQUEST_TIMEOUT_MS=25000

# PostgreSQL (production)
DB_HOST=prod-postgres.example.internal
DB_PORT=5432
DB_USER=museumia_prod
DB_PASSWORD=replace-with-secret
PGDATABASE=museumia_prod
DB_POOL_MAX=30
DB_SYNCHRONIZE=false

# JWT-only auth (REQUIRED)
JWT_ACCESS_SECRET=replace-with-very-strong-secret
JWT_REFRESH_SECRET=replace-with-very-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=180d
MEDIA_SIGNING_SECRET=replace-with-very-strong-secret

# Object storage (S3-compatible, private bucket + signed URLs)
OBJECT_STORAGE_DRIVER=s3
LOCAL_UPLOADS_DIR=tmp/uploads
S3_SIGNED_URL_TTL_SECONDS=900
S3_ENDPOINT=https://s3.example.com
S3_REGION=eu-west-1
S3_BUCKET=museumia-prod-private
S3_ACCESS_KEY_ID=replace-with-secret
S3_SECRET_ACCESS_KEY=replace-with-secret
# Optional temporary credentials (STS/IAM role style)
S3_SESSION_TOKEN=
# Optional prefix for environment partitioning (e.g. prod)
S3_OBJECT_KEY_PREFIX=prod
# Optional read URL base; supports "{bucket}" placeholder
S3_PUBLIC_BASE_URL=

# LLM provider (choose one and set matching key)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LLM_TEMPERATURE=0.3
LLM_PARALLEL_ENABLED=true
LLM_TIMEOUT_MS=15000
LLM_TIMEOUT_SUMMARY_MS=8000
LLM_TIMEOUT_EXPERT_COMPACT_MS=20000
LLM_TOTAL_BUDGET_MS=25000
LLM_RETRIES=1
LLM_RETRY_BASE_DELAY_MS=250
LLM_MAX_CONCURRENT=5
LLM_SECTIONS_MAX_CONCURRENT=2
LLM_MAX_HISTORY_MESSAGES=12
LLM_MAX_TEXT_LENGTH=2000
LLM_MAX_IMAGE_BYTES=3145728
LLM_MAX_AUDIO_BYTES=12582912
LLM_INCLUDE_DIAGNOSTICS=false
OPENAI_API_KEY=replace-with-secret
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Email delivery (optional, enables /api/support/contact forwarding)
BREVO_API_KEY=
SUPPORT_INBOX_EMAIL=support@musaium.app

# Rate limits (production)
RATE_LIMIT_IP=120
RATE_LIMIT_SESSION=60
RATE_LIMIT_WINDOW_MS=60000

# Upload validation
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/wav,audio/x-wav,audio/webm,audio/ogg,audio/aac

# ── Free tier ──
FREE_TIER_DAILY_CHAT_LIMIT=100

# ── Social sign-in (Apple + Google) ──
APPLE_CLIENT_ID=com.musaium.mobile
GOOGLE_OAUTH_CLIENT_ID=

# ── Sentry (error reporting + perf) ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0

# ── Cache / Redis ──
CACHE_ENABLED=true
# In docker-compose the service hostname is `redis`; in managed setups point at the provider.
REDIS_URL=redis://redis:6379
# REQUIRED in production — generate via: openssl rand -base64 32
# Must match `--requirepass` passed to the redis container in deploy/docker-compose.prod.yml.
REDIS_PASSWORD=replace-with-strong-redis-password
CACHE_SESSION_TTL_SECONDS=3600
CACHE_LIST_TTL_SECONDS=300

# ── Text-to-Speech (optional) ──
TTS_ENABLED=false
TTS_MODEL=tts-1
TTS_VOICE=alloy
TTS_SPEED=1.0
TTS_MAX_TEXT_LENGTH=4096
TTS_CACHE_TTL_SECONDS=86400

# ── Feature flags ──
FEATURE_FLAG_VOICE_MODE=false
FEATURE_FLAG_OCR_GUARD=false
FEATURE_FLAG_API_KEYS=false
FEATURE_FLAG_STREAMING=false
FEATURE_FLAG_USER_MEMORY=false
FEATURE_FLAG_MULTI_TENANCY=false
FEATURE_FLAG_KNOWLEDGE_EXTRACTION=true
# Output-side art-topic classifier (LLM). Default false — topic discipline via system prompt.
FEATURE_ART_TOPIC_CLASSIFIER=false

# ── AI Guardrails V2 (P11) ──
# Activates the LLM Guard sidecar for semantic injection detection + PII redaction
# + toxicity filtering. See docs/plans/reports/P11-decision.md for the Phase A/B/C
# rollout plan. Set CANDIDATE=off to install the noop adapter (V2 disabled).
GUARDRAILS_V2_CANDIDATE=llm-guard
GUARDRAILS_V2_LLM_GUARD_URL=http://llm-guard:8081
GUARDRAILS_V2_TIMEOUT_MS=500
# Phase A = observe-only (log decisions but never block). Flip to false only
# after 30 days of clean telemetry to enter Phase B (block at confidence >= 0.95).
GUARDRAILS_V2_OBSERVE_ONLY=true

# ── OpenTelemetry (observability) ──
OTEL_ENABLED=false
OTEL_SERVICE_NAME=museum-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_ENDPOINT=http://localhost:4318

# ── Overpass API cache (museum search) ──
OVERPASS_CACHE_TTL_SECONDS=86400

# ── Frontend URL (used in support emails) ──
FRONTEND_URL=https://musaium.com

# ── DB Backup (VPS cron only — not used by app runtime) ──
# BACKUP_DB_USER=museumia_backup
# BACKUP_DB_PASSWORD=
# BACKUP_DIR=/srv/museum/backups
# BACKUP_HEARTBEAT_URL=
