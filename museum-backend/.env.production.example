# Production environment template for museum-backend
#
# Copy to `.env.production` on the deployment target and fill every REPLACE_ME
# via your CI/CD secret store (GitHub Actions → OVH VPS).
#
# Re-audited 2026-06-12 against src/config/env.production-validation.ts — the
# previous template (2026-05-12) predated 6 boot gates and would NOT have
# booted. Verify any candidate with:  pnpm validate:prod-env -- .env.production
#
# Decisions for the 2026-08-27 launch:
#   - Object storage  = OVH Object Storage (S3-compatible)
#   - Langfuse        = ENABLED (requires signed DPA + EU host)
#   - image-compare   = SigLIP provisioned (build-time model, see §SigLIP)
#
# Cross-references:
# - docs/RELEASE_CHECKLIST.md (master launch gate list)
# - docs/operations/S3_PUBLIC_ACCESS_VERIFICATION.md (B19 attestation)
# - docs/operations/SIGLIP_MODEL_PROVISIONING.md (SIGLIP_ONNX_SHA256)
# - docs/compliance/SUBPROCESSORS.md / docs/legal/ROPA.md / docs/legal/DPIA.md

# === Runtime ===
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Surfaced in /api/health + Sentry release tag. Fallback: APP_VERSION → npm_package_version → 'unknown'.
APP_VERSION=REPLACE_ME

# === CORS (hard-gate: required) ===
# Comma-separated allowed origins (FE web + mobile webview redirects). No wildcard.
# Mirror exactly the prod domains; preflight failures = silent FE breakage.
CORS_ORIGINS=https://musaium.com,https://www.musaium.com,https://musaium.fr,https://www.musaium.fr

# === Database (PostgreSQL 16) ===
# Connection is read from DB_* + PGDATABASE (NOT DATABASE_URL — that var is
# ignored by env.ts). PGDATABASE is a hard-gate (env.ts:93 required).
# DB_SYNCHRONIZE is hard-coded false in data-source.ts for prod; CI blocks any truthy literal.
DB_HOST=db.internal
DB_PORT=5432
DB_USER=musaium
DB_PASSWORD=REPLACE_ME
PGDATABASE=musaium_prod
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SYNCHRONIZE=false
DB_POOL_MAX=50

# === App secrets (hard-gate: required, >=32 chars, MUTUALLY DISTINCT) ===
# Generate all of these with:  bash scripts/gen-prod-secrets.sh
# The boot wall (env.production-validation.ts) refuses to start if any is
# missing, shorter than 32 chars, or equal to another in the distinctness
# matrix. Do NOT reuse one value across two vars.
# NOTE: legacy JWT_SECRET is BANNED in prod (H12) — use JWT_ACCESS_SECRET.
JWT_ACCESS_SECRET=REPLACE_ME_32+_CHARS
JWT_REFRESH_SECRET=REPLACE_ME_32+_CHARS
CSRF_SECRET=REPLACE_ME_32+_CHARS
MEDIA_SIGNING_SECRET=REPLACE_ME_32+_CHARS
MFA_ENCRYPTION_KEY=REPLACE_ME_32+_CHARS
MFA_SESSION_TOKEN_SECRET=REPLACE_ME_32+_CHARS
EXPORT_PSEUDONYM_SALT=REPLACE_ME_32+_CHARS
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# === Redis (hard-gate: required in prod) ===
# REDIS_URL activates the cache object (REDIS_HOST alone does NOT — env.ts:245).
# Because OPENAI_USER_DAILY_USD_CAP defaults to 0.5 (>0), the cost-guard throws
# at boot unless the cache is active, so Redis is an EFFECTIVE hard requirement.
# REDIS_PASSWORD is read as a dedicated var, must be >=32 and distinct from the
# JWT/MEDIA secrets (env-resolvers.ts:45/57/68, validator :115/121/126/132/135).
REDIS_URL=redis://redis.internal:6379
REDIS_PASSWORD=REPLACE_ME_32+_CHARS
# Container-level caps (compose only, safe defaults — not app boot gates):
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=volatile-ttl
RATE_LIMIT_IP=120
RATE_LIMIT_SESSION=60
RATE_LIMIT_WINDOW_MS=60000

# === LLM providers ===
# OpenAI is the default provider → OPENAI_API_KEY is a hard-gate (validator :62).
# Deepseek = China, no EU adequacy; never enable without DEEPSEEK_EU_TRANSFER_APPROVED + TIA.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
OPENAI_API_KEY=REPLACE_ME
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# Per-user daily LLM cost cap (USD). Default 0.5. Setting 0 disables the cost-guard
# (which would also remove the Redis coupling above). Keep >0 in prod.
OPENAI_USER_DAILY_USD_CAP=0.5

# === Langfuse (ENABLED for launch — GDPR Art.28) ===
# DECISION: ON at launch. PREREQUISITES (operator, before real data flows):
#   1. Signed Langfuse DPA archived in docs/legal/dpa-signed/ (P0.B14).
#   2. EU region: cloud.langfuse.com IS the Europe region (AWS eu-west-1);
#      us.cloud.langfuse.com is the SEPARATE US region. Keys are per-region —
#      create the project on the Europe instance. This makes the /subprocessors
#      "internal (EU)" claim true. env.ts already defaults to cloud.langfuse.com (EU).
LANGFUSE_ENABLED=true
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=REPLACE_ME
LANGFUSE_SECRET_KEY=REPLACE_ME

# === Object storage — OVH Object Storage (S3-compatible) ===
# DECISION: OVH-s3. The boot wall REFUSES the s3 driver in prod unless you attest
# the bucket Public Access Block is ON (B19). User object keys are enumerable and
# the bucket holds photos + TTS voice audio (potential Art.9 biometric) →
# a public bucket = GDPR Art.32 breach.
# Procedure: docs/operations/S3_PUBLIC_ACCESS_VERIFICATION.md
#   §A enable PAB/private ACL on the OVH bucket → §D anonymous-GET test (expect 403)
#   → then flip S3_PUBLIC_ACCESS_BLOCK_VERIFIED=true.
OBJECT_STORAGE_DRIVER=s3
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=REPLACE_ME_OVH_BUCKET
S3_ACCESS_KEY_ID=REPLACE_ME
S3_SECRET_ACCESS_KEY=REPLACE_ME
S3_SIGNED_URL_TTL_SECONDS=900
S3_PUBLIC_ACCESS_BLOCK_VERIFIED=false
# Days to retain S3 orphan objects before purge (cron 30 4 * * *). Default 180.
S3_ORPHAN_PURGE_RETENTION_DAYS=180

# === SigLIP (image-compare) — build-time model integrity ===
# SIGLIP_ONNX_SHA256 is a Docker BUILD ARG (deploy/Dockerfile.prod), NOT a runtime
# env gate. Provision per docs/operations/SIGLIP_MODEL_PROVISIONING.md and set the
# CI secret (gh secret set SIGLIP_ONNX_SHA256). Without the model, /chat/compare
# returns 503 cold. Runtime model path (in-container) below:
SIGLIP_ONNX_MODEL_PATH=/app/models/siglip.onnx

# === Email (Brevo, EU/FR) ===
# AUTH_EMAIL_SERVICE_KIND default 'brevo'; prod BANS 'test' (would swallow real emails).
AUTH_EMAIL_SERVICE_KIND=brevo
BREVO_API_KEY=REPLACE_ME
SUPPORT_INBOX_EMAIL=support@musaium.com
FRONTEND_URL=https://musaium.com
# audit-chain-nightly fallback recipient when Slack webhook is unset/unreachable.
AUDIT_CHAIN_ALERT_EMAIL=m.rivet@expertgcl.fr

# === Web search providers ===
# Fallback chain: Tavily → Brave → Google CSE → SearXNG → DuckDuckGo. Each is wired
# only when its env key(s) are present; DuckDuckGo (keyless) is always the free tail.
# Tavily DISABLED until DPA signed (empty key = graceful fallback). Brave optional.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
# Google Programmable Search (US, DPF-certified) — needs BOTH; empty = skipped.
GOOGLE_CSE_API_KEY=REPLACE_ME
GOOGLE_CSE_ID=REPLACE_ME
# SearXNG — CSV of operator-vetted instance base URLs (no trailing slash). Empty = skipped.
# Each configured instance MUST be vetted before launch (cf. docs/compliance/SUBPROCESSORS.md #18).
SEARXNG_INSTANCES=https://searx.example.org

# === Auth (OAuth) ===
# Google Sign-In Web client id (public-by-design). Empty disables Google auth.
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com

# === Observability (Sentry EU region) ===
SENTRY_DSN=https://REPLACE_ME@oXXXX.ingest.de.sentry.io/REPLACE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.05

# === AI safety & guardrails (dual-layer, ADR-015) ===
# Layer 1 — LLM Guard sidecar (self-activates when URL set, fail-CLOSED).
GUARDRAILS_V2_LLM_GUARD_URL=http://llm-guard:8081
GUARDRAILS_V2_TIMEOUT_MS=1500
GUARDRAILS_V2_OBSERVE_ONLY=false
# Layer 2 — Structured-output judge (self-activates when budget > 0, runs in parallel).
LLM_GUARDRAIL_BUDGET_CENTS_PER_DAY=500
LLM_GUARDRAIL_JUDGE_TIMEOUT_MS=1500
LLM_GUARDRAIL_JUDGE_MIN_LENGTH=50
GUARDRAIL_BUDGET_BACKEND=redis

# === OpenStreetMap providers (Nominatim + Overpass) ===
NOMINATIM_CONTACT_EMAIL=contact@musaium.com
NOMINATIM_MIN_REQUEST_INTERVAL_MS=1000

# === Plausible funnel analytics (KR4) ===
# REQUIRED in prod for funnel emission; unset = silent no-op (warn-only, not a boot gate).
PLAUSIBLE_DOMAIN=REPLACE_ME_PLAUSIBLE_DOMAIN
PLAUSIBLE_ENDPOINT_URL=https://plausible.io/api/event
