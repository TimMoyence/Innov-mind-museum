# Production environment template for museum-backend
#
# Copy to `.env.production` on the deployment target and fill the real
# secrets via your CI/CD secret store (GitHub Actions → OVH VPS).
#
# Audited 2026-05-12 — every entry is either a documented prod value or
# a placeholder that MUST be replaced before going live.
#
# Cross-references:
# - docs/compliance/SUBPROCESSORS.md (Art. 28 ledger)
# - docs/legal/ROPA.md (Art. 30 registry)
# - docs/legal/DPIA.md (Art. 35 impact assessment)

# === Runtime ===
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# === Database ===
# PostgreSQL 16. Hard-coded `DB_SYNCHRONIZE=false` in `data-source.ts` for
# prod (CI blocks any DB_SYNCHRONIZE truthy literal found anywhere).
DATABASE_URL=postgres://musaium:REPLACE_ME@db.internal:5432/musaium_prod
DB_SYNCHRONIZE=false

# === LLM providers ===
# OpenAI is the default. Google is an alternative. Deepseek is hosted in
# China and has no EU adequacy decision — never enable in production for
# EU residents until SCC + TIA are signed (cf SUBPROCESSORS #2).
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
OPENAI_API_KEY=REPLACE_ME
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# === Web search providers ===
# Tavily is currently DISABLED in production until the DPA is signed.
# Tavily ships no public DPA URL (SUBPROCESSORS #15) — SCC requested in
# writing, outcome tracked in team-reports/. Empty key triggers a graceful
# fallback chain (`chat-module.ts:263` skips the provider when the key is
# absent).
# DISABLED: DPA pending — re-enable when signed (Owner: Tim, target 2026-Q3)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=REPLACE_ME

# === Object storage (S3-compatible) ===
# AWS S3 eu-west-3 (Paris) keeps user-uploaded photos + TTS audio inside
# the EU — no Art. 44-49 transfer triggered. NEVER point this at the legacy
# `s3.example.com` placeholder in production; the audit flagged that exact
# value as a deploy blocker.
OBJECT_STORAGE_DRIVER=s3
AWS_S3_ENDPOINT=https://s3.eu-west-3.amazonaws.com
S3_ENDPOINT=https://s3.eu-west-3.amazonaws.com
S3_REGION=eu-west-3
S3_BUCKET=musaium-prod-eu-west-3
S3_ACCESS_KEY_ID=REPLACE_ME
S3_SECRET_ACCESS_KEY=REPLACE_ME
S3_SIGNED_URL_TTL_SECONDS=900

# === Email (Brevo, EU/FR) ===
BREVO_API_KEY=REPLACE_ME
SUPPORT_INBOX_EMAIL=support@musaium.app
FRONTEND_URL=https://musaium.app

# audit-chain-nightly fallback when DEPLOY_ALERT_SLACK_WEBHOOK is unset/unreachable.
# Reuses BREVO_API_KEY above; recipient is the tech-lead alert mailbox.
AUDIT_CHAIN_ALERT_EMAIL=m.rivet@expertgcl.fr

# === Auth ===
JWT_SECRET=REPLACE_ME_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=REPLACE_ME_AT_LEAST_64_CHARS
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# === Observability ===
# Sentry EU region (`*.eu.sentry.io`) — confirmed in SUBPROCESSORS #6.
SENTRY_DSN=https://REPLACE_ME@oXXXX.ingest.de.sentry.io/REPLACE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05

# === Rate limiting (Redis-backed in prod) ===
REDIS_URL=redis://redis.internal:6379
RATE_LIMIT_IP=120
RATE_LIMIT_SESSION=60
RATE_LIMIT_WINDOW_MS=60000

# === AI safety & guardrails ===
# llm-guard sidecar activates automatically when this URL is set
# (master GUARDRAILS_V2_CANDIDATE flag retired 2026-05-14, ADR-015 amendment).
GUARDRAILS_V2_LLM_GUARD_URL=http://llm-guard:8081

# === OpenStreetMap providers (Nominatim + Overpass) ===
NOMINATIM_CONTACT_EMAIL=contact@musaium.app
NOMINATIM_MIN_REQUEST_INTERVAL_MS=1000
