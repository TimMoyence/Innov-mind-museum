{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": false,
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "target": "es2022",
    "keepClassNames": true,
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@data/*": ["src/data/*"],
      "@shared/*": ["src/shared/*"],
      "tests/*": ["tests/*"]
    }
  },
  "module": {
    "type": "commonjs"
  },
  "sourceMaps": true
}
