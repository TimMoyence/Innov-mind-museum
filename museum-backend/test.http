  "lastname": "Le big T"
}


### ? Login user
POST https://musaium.com/api/auth/login
Content-Type: application/json

{
  "email": "tim.moyence@gamil.com",
  "password": "Test123456!"
}

### ? forgot-password user
POST https://musaium.com/api/auth/forgot-password
Content-Type: application/json

{
  "email": "tim.moyence@outlook.fr"
}

### ? reset-password user
POST https://musaium.com/api/auth/reset-password
Content-Type: application/json

{
  "token" :"54aa061a6c7d37ad42b2238db42c100484790b42",
  "newPassword" : "Test123456!"
}

### ? send audio message in chat session
POST http://localhost:3000/api/chat/sessions/{{sessionId}}/audio
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=Boundary

--Boundary
Content-Disposition: form-data; name="context"

{"museumMode":true,"locale":"fr-FR","guideLevel":"beginner"}
--Boundary
Content-Disposition: form-data; name="audio"; filename="voice-note.m4a"
Content-Type: audio/mp4

< ./fixtures/voice-note.m4a
--Boundary--
