{
  "rest": {
    "RestGenerator": {
      "name": "musaium-chat",
      "uri": "http://localhost:3000/api/chat/sessions/$SESSION_ID/messages",
      "method": "POST",
      "headers": {
        "Authorization": "Bearer $MUSAIUM_JWT",
        "Content-Type": "application/json"
      },
      "req_template_json_object": {
        "text": "$INPUT"
      },
      "response_json": true,
      "response_json_field": "$.message.text",
      "request_timeout": 30,
      "ratelimit_codes": [429]
    }
  }
}
