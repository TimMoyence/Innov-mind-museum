# Musaium backend - local development (.env.local.example)
# Usage: cp .env.local.example .env
# local = dev machine

NODE_ENV=development
PORT=3000
TRUST_PROXY=false
APP_VERSION=local-dev
COMMIT_SHA=local

# Comma-separated allowlist for local frontend / Expo / web
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
JSON_BODY_LIMIT=5mb
REQUEST_TIMEOUT_MS=20000

# PostgreSQL (local or docker-compose)
DB_HOST=localhost
DB_PORT=5433
DB_USER=
DB_PASSWORD=
PGDATABASE=museum_ia
DB_POOL_MAX=20
DB_SYNCHRONIZE=false
# DB_SSL_REJECT_UNAUTHORIZED=false  # set true if DB has valid CA-signed cert

# JWT-only auth (required)
JWT_ACCESS_SECRET=replace-with-local-access-secret
JWT_REFRESH_SECRET=replace-with-local-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Social sign-in (Apple + Google)
APPLE_CLIENT_ID=com.musaium.mobile
GOOGLE_OAUTH_CLIENT_ID=

# Media signing for image URLs (falls back to JWT_ACCESS_SECRET if omitted, but explicit is better)
MEDIA_SIGNING_SECRET=replace-with-local-media-signing-secret

# Object storage: local for dev (S3 fields ignored when OBJECT_STORAGE_DRIVER=local)
OBJECT_STORAGE_DRIVER=local
LOCAL_UPLOADS_DIR=tmp/uploads
S3_SIGNED_URL_TTL_SECONDS=900

# S3-compatible settings (for future local MinIO tests)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_OBJECT_KEY_PREFIX=
# Optional read URL base. Supports "{bucket}" placeholder, e.g. https://cdn.example.com/{bucket}
S3_PUBLIC_BASE_URL=

# LLM config (one provider active)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_MS=15000
LLM_TIMEOUT_SUMMARY_MS=8000
LLM_TOTAL_BUDGET_MS=25000
LLM_RETRIES=1
LLM_RETRY_BASE_DELAY_MS=250
LLM_MAX_CONCURRENT=5
LLM_MAX_HISTORY_MESSAGES=12
LLM_MAX_TEXT_LENGTH=2000
LLM_MAX_IMAGE_BYTES=3145728
LLM_MAX_AUDIO_BYTES=12582912
LLM_INCLUDE_DIAGNOSTICS=true
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# AI integration tests (requires OPENAI_API_KEY above)
# RUN_AI_TESTS=false

# Free-tier daily chat limit (messages per user per calendar day)
FREE_TIER_DAILY_CHAT_LIMIT=100

# Rate limits
RATE_LIMIT_IP=120
RATE_LIMIT_SESSION=60
RATE_LIMIT_WINDOW_MS=60000

# Cache / Redis (optional — disabled by default for local dev)
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379
CACHE_SESSION_TTL_SECONDS=3600
CACHE_LIST_TTL_SECONDS=300

# Text-to-Speech (optional — disabled by default)
TTS_ENABLED=false
TTS_MODEL=tts-1
TTS_VOICE=alloy
TTS_SPEED=1.0
TTS_MAX_TEXT_LENGTH=4096
TTS_CACHE_TTL_SECONDS=86400

# Feature flags (all off by default)
FEATURE_FLAG_VOICE_MODE=false
FEATURE_FLAG_OCR_GUARD=false
FEATURE_FLAG_API_KEYS=false
FEATURE_FLAG_STREAMING=false
FEATURE_FLAG_USER_MEMORY=false
FEATURE_FLAG_MULTI_TENANCY=false

# Overpass API cache (museum search — optional)
OVERPASS_CACHE_TTL_SECONDS=86400

# Email (Brevo — optional for local dev)
# BREVO_API_KEY=
# FRONTEND_URL=http://localhost:8081

# Upload validation
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/wav,audio/x-wav,audio/webm,audio/ogg,audio/aac

# Sentry (optional — disabled when SENTRY_DSN is empty)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0

# OpenTelemetry (optional — disabled by default)
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=museum-backend

# DB Backup (VPS cron only — not used by app runtime)
# BACKUP_DB_USER=museumia_backup
# BACKUP_DB_PASSWORD=
# BACKUP_DIR=/srv/museum/backups
# BACKUP_HEARTBEAT_URL=
