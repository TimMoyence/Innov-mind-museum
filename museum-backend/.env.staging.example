# Musaium backend - preprod/staging (.env.staging.example)
# Usage on staging server: cp .env.staging.example .env
# preprod = staging

NODE_ENV=production
PORT=3000
TRUST_PROXY=true
APP_VERSION=1.0.0-staging
COMMIT_SHA=replace-at-deploy-time

# REQUIRED: explicit allowed origins only (no wildcard)
CORS_ORIGINS=https://staging-api.example.com,https://preview-app.example.com
JSON_BODY_LIMIT=5mb
REQUEST_TIMEOUT_MS=25000

# PostgreSQL (staging)
DB_HOST=staging-postgres.example.internal
DB_PORT=5432
DB_USER=museumia_staging
DB_PASSWORD=replace-with-secret
PGDATABASE=museumia_staging
DB_POOL_MAX=20
DB_SYNCHRONIZE=false

# JWT-only auth (REQUIRED)
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
MEDIA_SIGNING_SECRET=replace-with-strong-secret

# Object storage (S3-compatible, private bucket + signed URLs)
OBJECT_STORAGE_DRIVER=s3
LOCAL_UPLOADS_DIR=tmp/uploads
S3_SIGNED_URL_TTL_SECONDS=900
S3_ENDPOINT=https://s3.example.com
S3_REGION=eu-west-1
S3_BUCKET=museumia-staging-private
S3_ACCESS_KEY_ID=replace-with-secret
S3_SECRET_ACCESS_KEY=replace-with-secret
# Optional temporary credentials (STS/IAM role style)
S3_SESSION_TOKEN=
# Optional prefix for environment partitioning (e.g. staging)
S3_OBJECT_KEY_PREFIX=staging
# Optional read URL base; supports "{bucket}" placeholder
S3_PUBLIC_BASE_URL=

# LLM provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LLM_TEMPERATURE=0.3
LLM_PARALLEL_ENABLED=true
LLM_TIMEOUT_MS=15000
LLM_TIMEOUT_SUMMARY_MS=8000
LLM_TIMEOUT_EXPERT_COMPACT_MS=20000
LLM_TOTAL_BUDGET_MS=25000
LLM_RETRIES=1
LLM_RETRY_BASE_DELAY_MS=250
LLM_MAX_CONCURRENT=5
LLM_SECTIONS_MAX_CONCURRENT=2
LLM_MAX_HISTORY_MESSAGES=12
LLM_MAX_TEXT_LENGTH=2000
LLM_MAX_IMAGE_BYTES=3145728
LLM_MAX_AUDIO_BYTES=12582912
LLM_INCLUDE_DIAGNOSTICS=false
OPENAI_API_KEY=replace-with-secret
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Email delivery (optional, enables /api/support/contact forwarding)
BREVO_API_KEY=
SUPPORT_INBOX_EMAIL=support@musaium.app

# Rate limits (staging can be higher during QA)
RATE_LIMIT_IP=500
RATE_LIMIT_SESSION=200
RATE_LIMIT_WINDOW_MS=60000

# Upload validation
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/wav,audio/x-wav,audio/webm,audio/ogg,audio/aac

# ── Free tier ──
FREE_TIER_DAILY_CHAT_LIMIT=100

# ── Social sign-in (Apple + Google) ──
APPLE_CLIENT_ID=com.musaium.mobile
GOOGLE_OAUTH_CLIENT_ID=

# ── Sentry (error reporting + perf) ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0

# ── Cache / Redis ──
CACHE_ENABLED=true
REDIS_URL=redis://staging-redis.example.internal:6379
CACHE_SESSION_TTL_SECONDS=3600
CACHE_LIST_TTL_SECONDS=300

# ── Text-to-Speech (optional) ──
TTS_ENABLED=false
TTS_MODEL=tts-1
TTS_VOICE=alloy
TTS_SPEED=1.0
TTS_MAX_TEXT_LENGTH=4096
TTS_CACHE_TTL_SECONDS=86400

# ── Feature flags ──
FEATURE_FLAG_VOICE_MODE=false
FEATURE_FLAG_OCR_GUARD=false
FEATURE_FLAG_API_KEYS=false
FEATURE_FLAG_STREAMING=false
FEATURE_FLAG_USER_MEMORY=false
FEATURE_FLAG_MULTI_TENANCY=false
FEATURE_FLAG_KNOWLEDGE_EXTRACTION=true

# ── OpenTelemetry (observability) ──
OTEL_ENABLED=false
OTEL_SERVICE_NAME=museum-backend-staging
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_ENDPOINT=http://localhost:4318

# ── Overpass API cache (museum search) ──
OVERPASS_CACHE_TTL_SECONDS=86400

# ── Frontend URL (used in support emails) ──
FRONTEND_URL=https://staging.musaium.com

# ── DB Backup (VPS cron only — not used by app runtime) ──
# BACKUP_DB_USER=museumia_backup
# BACKUP_DB_PASSWORD=
# BACKUP_DIR=/srv/museum/backups
# BACKUP_HEARTBEAT_URL=
