{
  "name": "musaium-backend",
  "version": "1.0.0",
  "description": "",
  "packageManager": "pnpm@9.15.3",
  "main": "index.ts",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node -r tsconfig-paths/register src/index.ts",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "rm -rf dist && tsc && tsc-alias",
    "start:prod": "node dist/src/index.js",
    "lint": "eslint src/ && tsc --noEmit",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "openapi:validate": "node ./scripts/check-openapi-spec.cjs",
    "smoke:api": "node ./scripts/smoke-api.cjs",
    "test": "jest --watchman=false --runInBand",
    "test:ai": "RUN_AI_TESTS=true jest --watchman=false --runInBand --testPathPattern=tests/ai/ --testPathIgnorePatterns '/dist/' '/node_modules/'",
    "test:contract:openapi": "jest --watchman=false --runInBand tests/contract/openapi/openapi-response.contract.test.ts",
    "test:e2e": "RUN_E2E=true jest --watchman=false --runInBand --testPathPattern=tests/e2e/ --forceExit",
    "perf:auth": "k6 run tests/perf/k6/auth-flow.k6.js",
    "perf:chat": "k6 run tests/perf/k6/chat-flow.k6.js",
    "perf:load": "k6 run tests/perf/k6/concurrent-users.k6.js",
    "perf:chat:mock": "ts-node -r tsconfig-paths/register tests/perf/chat-load.mocked.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/data/db/data-source.ts",
    "migration:create": "node ./scripts/migration-cli.cjs create",
    "migration:generate": "node ./scripts/migration-cli.cjs generate",
    "migration:new": "npm run migration:generate --",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:revert": "npm run typeorm -- migration:revert",
    "purge:tokens": "ts-node -r tsconfig-paths/register scripts/purge-expired-tokens.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "ts-node": {
    "files": true
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@^1.1.7": "1.1.12",
      "brace-expansion@^2.0.1": "2.0.2",
      "diff": "4.0.4",
      "form-data": "4.0.5",
      "js-yaml@^3.13.1": "3.14.2",
      "jws@^3.2.2": "3.2.3",
      "minimatch@^3.0.0": "3.1.4",
      "minimatch@^9.0.0": "9.0.7",
      "qs": "6.15.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/types": "^29.6.3",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.14",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.1.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "readline-sync": "^1.4.10",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.15",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@langchain/core": "^0.3.80",
    "@langchain/google-genai": "^0.2.5",
    "@langchain/openai": "^0.5.7",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.45.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "1.4.5-lts.2",
    "pg": "^8.15.6",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "tesseract.js": "^7.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix"
  }
}
