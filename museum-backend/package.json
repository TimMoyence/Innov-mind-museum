{
  "name": "musaium-backend",
  "version": "1.0.3",
  "description": "",
  "packageManager": "pnpm@10.8.0",
  "main": "index.ts",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node -r tsconfig-paths/register src/index.ts",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "rm -rf dist && tsc && tsc-alias",
    "start:prod": "node dist/src/index.js",
    "lint": "eslint src/ --max-warnings=50 && tsc --noEmit",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "openapi:validate": "node ./scripts/check-openapi-spec.cjs",
    "smoke:api": "node ./scripts/smoke-api.cjs",
    "test": "jest --watchman=false --runInBand",
    "test:ai": "RUN_AI_TESTS=true jest --watchman=false --runInBand --testPathPattern=tests/ai/ --testPathIgnorePatterns '/dist/' '/node_modules/'",
    "test:contract:openapi": "jest --watchman=false --runInBand --coverage=false tests/contract/openapi/openapi-response.contract.test.ts",
    "test:e2e": "RUN_E2E=true jest --watchman=false --runInBand --testPathPattern=tests/e2e/ --forceExit",
    "perf:auth": "k6 run tests/perf/k6/auth-flow.k6.js",
    "perf:chat": "k6 run tests/perf/k6/chat-flow.k6.js",
    "perf:load": "k6 run tests/perf/k6/concurrent-users.k6.js",
    "perf:chat:mock": "ts-node -r tsconfig-paths/register tests/perf/chat-load.mocked.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/data/db/data-source.ts",
    "migration:create": "node ./scripts/migration-cli.cjs create",
    "migration:generate": "node ./scripts/migration-cli.cjs generate",
    "migration:new": "npm run migration:generate --",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:revert": "npm run typeorm -- migration:revert",
    "purge:tokens": "ts-node -r tsconfig-paths/register scripts/purge-expired-tokens.ts",
    "seed:museums": "ts-node -r tsconfig-paths/register scripts/seed-museums.ts",
    "seed:knowledge": "ts-node -r tsconfig-paths/register scripts/seed-knowledge.ts",
    "mutation": "stryker run",
    "mutation:ci": "stryker run --incremental --concurrency 2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "ts-node": {
    "files": true
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@^1.1.7": "1.1.13",
      "brace-expansion@^2.0.1": "2.0.2",
      "diff": "4.0.4",
      "form-data": "4.0.5",
      "js-yaml@^3.13.1": "3.14.2",
      "jws@^3.2.2": "3.2.3",
      "minimatch@^3.0.0": "3.1.4",
      "minimatch@^9.0.0": "9.0.7",
      "qs": "6.15.0",
      "path-to-regexp": "8.4.0",
      "langsmith": ">=0.4.6",
      "brace-expansion@>=4.0.0": ">=5.0.5",
      "handlebars": ">=4.7.9",
      "picomatch": ">=2.3.2"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/types": "^29.6.3",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.4.2",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.47.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.4",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "linkedom": "^0.18.12",
    "multer": "2.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "tesseract.js": "^7.0.0"
  },
  "pnpm": {
    "overrides": {
      "langsmith": ">=0.5.20",
      "protobufjs": ">=7.5.5",
      "handlebars": ">=4.7.9"
    }
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ]
  }
}
