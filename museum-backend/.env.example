# ! Musaium backend - staging/production (.env.example)
# === General ===
NODE_ENV=production
ENV=production
PORT=3000
TRUST_PROXY=true
APP_VERSION=1.0.0
# TTS_ENABLED retired 2026-04 (voice pipeline always on — cf docs/AI_VOICE.md).

# ═══════════════════════════════════════════════
# Web Search — Multi-Provider Fallback Chain
# ═══════════════════════════════════════════════
# Provider 1: Tavily (best quality, 1000 free/month)
TAVILY_API_KEY=

# Provider 2: Brave Search (2000 free/month)
BRAVE_SEARCH_API_KEY=

# Provider 3: Google Programmable Search (Custom Search JSON API, 100 free/day).
# Needs BOTH the API key and the engine id (cx) — wired only if both are set.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Provider 4: SearXNG — operator-hosted metasearch. CSV of vetted instance base
# URLs (no trailing slash). Each instance MUST be vetted (cf. docs/compliance/SUBPROCESSORS.md #18).
# Example: SEARXNG_INSTANCES=https://searx.example.org,https://search.self-hosted.example
SEARXNG_INSTANCES=

# Provider 5: DuckDuckGo Instant Answer — no key needed, always-on free tail.

# Shared config
WEB_SEARCH_TIMEOUT_MS=3000 
WEB_SEARCH_CACHE_TTL_SECONDS=3600 
WEB_SEARCH_MAX_RESULTS=5

# ═══════════════════════════════════════════════
# C4.1 — KnowledgeRouter cascade (KB → judge → WebSearch)
# ═══════════════════════════════════════════════
# TUNING-ONLY block (D11 / pré-launch V1 doctrine — see CLAUDE.md AI Safety +
# feedback_no_feature_flags_prelaunch). NO `*_ENABLED` switch. Rollback path
# is `git revert <merge-sha>`. Defaults match docs/adr/ADR-038 §Phase D4.
# Confidence cutoff (0..1). When judge ≥ threshold, WebSearch is skipped.
WEBSEARCH_FALLBACK_THRESHOLD=0.7
# Per-leg KB lookup budget (ms). Externally enforced — wraps Wikidata client.
KNOWLEDGE_ROUTER_KB_TIMEOUT_MS=200
# Per-leg LLM judge budget (ms). Mirrors LLM_GUARDRAIL_JUDGE_TIMEOUT_MS default.
KNOWLEDGE_ROUTER_JUDGE_TIMEOUT_MS=500
# Per-leg WebSearch budget (ms). Tighter than WEB_SEARCH_TIMEOUT_MS so the
# cascade's worst-case latency stays inside the chat p99 budget.
KNOWLEDGE_ROUTER_WS_TIMEOUT_MS=1500

# ── AI Guardrails V2 (P11) — dual-layer defense-in-depth (ADR-015 amendment 2026-05-14) ──
# Layer 1 — LLM Guard sidecar (Python, fail-CLOSED HTTP, free / self-hosted).
# URL presence is the toggle (master CANDIDATE flag retired 2026-05-14).
GUARDRAILS_V2_LLM_GUARD_URL=http://llm-guard:8081
GUARDRAILS_V2_TIMEOUT_MS=1500
GUARDRAILS_V2_OBSERVE_ONLY=false
# C9.8 (2026-05-17) — Microsoft Presidio analyzer+anonymizer alternative
# provider. When PRESIDIO_ENABLED=true AND PRESIDIO_BASE_URL set, Presidio
# replaces LLM Guard as the V2 provider. Pair with GUARDRAILS_V2_OBSERVE_ONLY
# =true for the 4-7d bake before flipping to enforce. ADR-051.
PRESIDIO_ENABLED=false
PRESIDIO_BASE_URL=
PRESIDIO_TIMEOUT_MS=500
# Layer 2 — Structured-output judge (OpenAI LLM-as-judge). BUDGET > 0 = ON.
LLM_GUARDRAIL_BUDGET_CENTS_PER_DAY=500
LLM_GUARDRAIL_JUDGE_TIMEOUT_MS=500
LLM_GUARDRAIL_JUDGE_MIN_LENGTH=50
GUARDRAIL_BUDGET_BACKEND=memory
# Layer 3 — Hybrid-by-gravity friction (2026-06-01). Repeat-offender escalation:
# weighted counters (security blocks weigh more than off-topic) accumulate per
# session/user; once a threshold is crossed, a short friction cooldown is
# applied. Tuning-only, NO `*_ENABLED`-as-feature-flag bypass (the ENABLED here
# is the kill path = revert; pré-launch V1 doctrine).
GUARDRAIL_FRICTION_ENABLED=true
# Counter backend (mirror of GUARDRAIL_BUDGET_BACKEND): `memory` = per-process
# (dev/test/single-instance); anything else (e.g. `redis`) = shared via the
# CacheService incrBy + TTL (prod multi-instance). FAIL-SOFT on outage.
GUARDRAIL_FRICTION_BACKEND=memory
FRICTION_SESSION_THRESHOLD=3
FRICTION_USER_THRESHOLD=10
FRICTION_SESSION_TTL_MS=21600000
FRICTION_USER_TTL_MS=86400000
FRICTION_COOLDOWN_MS=120000
FRICTION_WEIGHT_SECURITY=2
FRICTION_WEIGHT_OFFTOPIC=1

# BullMQ Queue 
EXTRACTION_QUEUE_CONCURRENCY=2
EXTRACTION_QUEUE_RATE_LIMIT=60

# Scraper
EXTRACTION_SCRAPE_TIMEOUT_MS=5000
EXTRACTION_CONTENT_MAX_BYTES=51200
EXTRACTION_REFETCH_AFTER_DAYS=7 
 
# LLM Classifier (via LangChain)
EXTRACTION_LLM_MODEL=gpt-4o-mini 
EXTRACTION_CONFIDENCE_THRESHOLD=0.7 
EXTRACTION_REVIEW_THRESHOLD=0.4

# === Network ===
CORS_ORIGINS=https://musaium.com,https://www.musaium.com,https://musaium.fr,https://www.musaium.fr,https://museum.asilidesign.fr
JSON_BODY_LIMIT=5mb
REQUEST_TIMEOUT_MS=20000

# === Database ===
PGDATABASE=museumAI
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MAX=20
DB_SYNCHRONIZE=false
DB_SSL=false

# Social sign-in (Apple + Google)
APPLE_CLIENT_ID=com.musaium.mobile
GOOGLE_OAUTH_CLIENT_ID=498339023976-bjbain2ir2t9q4pu9lsmmk8ni7t96dd7.apps.googleusercontent.com
GOOGLE_OAUTH_WEB_CLIENT_ID=498339023976-bjbain2ir2t9q4pu9lsmmk8ni7t96dd7.apps.googleusercontent.com
GOOGLE_OAUTH_WEB_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://musaium.com/api/auth/google/callback
# === Auth ===
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
MEDIA_SIGNING_SECRET=

# === LLM ===
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_MS=15000
LLM_TIMEOUT_SUMMARY_MS=8000
LLM_TOTAL_BUDGET_MS=25000
LLM_RETRIES=1
LLM_RETRY_BASE_DELAY_MS=250
LLM_MAX_CONCURRENT=5
LLM_MAX_HISTORY_MESSAGES=12
LLM_MAX_TEXT_LENGTH=2000
LLM_MAX_IMAGE_BYTES=3145728
LLM_MAX_AUDIO_BYTES=12582912
LLM_INCLUDE_DIAGNOSTICS=false
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# COMP-04 — DeepSeek (api.deepseek.com, China) has no EU adequacy decision.
# LLM_PROVIDER=deepseek is BLOCKED at boot in production (Schrems II) unless you
# consciously accept the cross-border transfer risk by setting this to true AND
# documenting the decision in docs/legal/ROPA.md. Leave unset for openai/google.
DEEPSEEK_EU_TRANSFER_APPROVED=

# === Storage ===
OBJECT_STORAGE_DRIVER=local
LOCAL_UPLOADS_DIR=/app/tmp/uploads
S3_SIGNED_URL_TTL_SECONDS=900
# Retention window for s3-orphan-purge-cron (days). Objects older than this AND
# unreferenced by any chat_messages row are deleted. Independent of
# CHAT_PURGE_RETENTION_DAYS so the two windows can differ. Default: 180.
S3_ORPHAN_PURGE_RETENTION_DAYS=180

# === Rate Limiting ===
RATE_LIMIT_IP=120
RATE_LIMIT_SESSION=60
RATE_LIMIT_WINDOW_MS=60000

# === Upload ===
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/wav,audio/x-wav,audio/webm,audio/ogg,audio/aac

# === Observability ===
SENTRY_DSN=REPLACE_ME_DEV_SENTRY_DSN
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0

# Overpass API cache (museum search — optional)
OVERPASS_CACHE_TTL_SECONDS=86400 

# === Cache (Redis) ===
CACHE_ENABLED=true
REDIS_URL=
CACHE_SESSION_TTL_SECONDS=3600
CACHE_LIST_TTL_SECONDS=300
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# C4 I-SEC1 (2026-05-21) — hard memory cap + deterministic eviction.
# Default 512mb fits the single-VM OVH topology (~16 Gb RAM total, Postgres +
# Node + BullMQ workers leave headroom). Tune via env without redeploy. Wired
# into museum-backend/deploy/docker-compose.prod.yml redis `command:`.
REDIS_MAXMEMORY=512mb
# `volatile-ttl` evicts the WITH-TTL key whose remaining TTL is smallest
# first. Preserves llm_cost counters (25h TTL) over cache (1h TTL) under
# memory pressure → no financial-DoS via OOM eviction. Do NOT switch to
# `allkeys-*` without revisiting design.md §9 D5. Compose-parity sentinel
# (scripts/sentinels/compose-parity.mjs) enforces dev↔prod policy parity.
REDIS_MAXMEMORY_POLICY=volatile-ttl

# === Email ===
BREVO_API_KEY=
# SMTP_BREVO retired Wave C6 lot p0 (alias of BREVO_API_KEY, never referenced in src).
# audit-chain-nightly email fallback when slack webhook is unset
AUDIT_CHAIN_ALERT_EMAIL=
# R4 W4.3 — B2B leads inbox. Config value, not a feature flag. Leave empty to
# route B2B leads to SUPPORT_INBOX_EMAIL (default behavior in local dev).
B2B_INBOX_EMAIL=
# R3 W4.2 — Brevo contact-list ID for the public beta waitlist. Config value
# (numeric Brevo list ID), NOT a feature flag (mirror B2B_INBOX_EMAIL
# precedent). Empty → BetaSignupNotifier fallback noop (route still returns
# 202, structured `beta_signup_notifier_noop` warn surfaces in logs).
BREVO_BETA_LIST_ID=
# R2 W3.4 — Salt for admin CSV export pseudonymization. Config value, NOT a
# feature flag (mirror B2B_INBOX_EMAIL precedent). REQUIRED in production:
# `validateProductionEnv` throws if unset or < 32 chars (I-SEC5, 2026-05-21).
# Generate via `openssl rand -hex 32` (or any 32+ char high-entropy string).
# Rotate manually after a breach — rotating invalidates the link between
# pseudonym and identity in already-exported CSV files (this is the property
# we want: leaked CSVs become non-correlatable post-rotation). Rotation
# doctrine: docs/SECURITY.md#export-salt-rotation.
EXPORT_PSEUDONYM_SALT=

# === FORGOT PASSWORD ===
FRONTEND_URL=https://musaium.com

JWT_ACCESS_SECRET=
MFA_ENCRYPTION_KEY=
MFA_SESSION_TOKEN_SECRET=
CSRF_SECRET=

# ═══════════════════════════════════════════════ 
# TELEMETRIE 
# ═══════════════════════════════════════════════

# GRAPHANA
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=https://musaium.fr/grafana

# TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════
# C3 — VISUAL SIMILARITY (chat/compare)
# ═══════════════════════════════════════════════
# `EMBEDDINGS_PROVIDER=siglip-onnx` self-hosts SigLIP base ONNX on CPU (no
# per-call cost, ~0.6–1.5s/encode). Switch to `replicate` to use the managed
# fallback when the ONNX model is unavailable (per-call cost, network latency).
EMBEDDINGS_PROVIDER=siglip-onnx
# Must match the prod build COPY target (deploy/Dockerfile.prod) and the local
# pull script (scripts/pull-siglip-model.sh) — siglip2 = v2 self-hosted ONNX; the
# v1 `siglip-base-patch16-224` name belongs to the Replicate model only. For
# local dev, run `bash scripts/pull-siglip-model.sh` to fetch this file.
SIGLIP_ONNX_MODEL_PATH=./models/siglip2-base-patch16-224.onnx
# REPLICATE_API_TOKEN= # only needed when EMBEDDINGS_PROVIDER=replicate
EMBEDDINGS_DIM=768
VISUAL_TOP_N=20
VISUAL_TOP_K_DEFAULT=5
VISUAL_W_VISUAL=0.7
VISUAL_W_META=0.3
VISUAL_FALLBACK_VISUAL_THRESHOLD=0.4
EMBEDDINGS_CACHE_TTL_MS=3600000
EMBEDDINGS_ENCODE_TIMEOUT_MS=3000

# ═══════════════════════════════════════════════
# C5 — WIKIDATA RÉSILIENT (circuit-breaker + local dump fallback)
# ═══════════════════════════════════════════════
# Tuning only — no *_ENABLED switches (pré-launch V1 doctrine, rollback = git revert).
WIKIDATA_USER_AGENT=Musaium/1.0 (https://musaium.app; contact@musaium.app)
# Opossum circuit-breaker around the Wikidata SPARQL/API client (C5.1).
WIKIDATA_CB_TIMEOUT_MS=5000
WIKIDATA_CB_ERROR_THRESHOLD_PCT=50
WIKIDATA_CB_RESET_TIMEOUT_MS=30000
WIKIDATA_CB_VOLUME_THRESHOLD=5
WIKIDATA_CB_CAPACITY=5
# Cascade soak (ms) before consulting the local dump while breaker stays OPEN (C5.3).
LOCAL_DUMP_FALLBACK_AFTER_MS=60000

# ═══════════════════════════════════════════════
# P0-4 — LLM cost guard (kill-switch + per-user daily USD cap)
# ═══════════════════════════════════════════════
# Operational tunables, NOT feature flags (pré-launch V1 doctrine).
LLM_KILL_SWITCH=false                    # global panic button — fail-CLOSED when true
OPENAI_USER_DAILY_USD_CAP=0.50           # per-user daily USD ceiling; anon callers bypass

# ═══════════════════════════════════════════════
# R1 (C6) — Soft-paywall monthly session quota
# ═══════════════════════════════════════════════
# Config value (numeric), pas feature flag. Default 3 si non set.
# Discipline `feedback_no_feature_flags_prelaunch` — disabling the paywall = revert R1, never bump to a huge number.
FREE_TIER_MONTHLY_SESSION_LIMIT=3

# ═══════════════════════════════════════════════
# Wave C5 (D-C5) — Plausible funnel analytics
# ═══════════════════════════════════════════════
# Both vars OPTIONAL : if either is unset, the PlausibleAdapter no-ops (silent
# fallback). Dev / test environments should keep them empty to avoid emitting
# spurious events into the prod dashboard.
# Cf. `museum-backend/docs/observability/PLAUSIBLE_FUNNEL.md` + `lib-docs/plausible/PATTERNS.md`.
PLAUSIBLE_DOMAIN=
PLAUSIBLE_ENDPOINT_URL=

# ═══════════════════════════════════════════════
# Review / NPS (KR2)
# ═══════════════════════════════════════════════
# NPS scale-epoch (F3). The review rating scale switched 1-5 (legacy stars) →
# 0-10 (NPS). `aggregateNps` counts ONLY reviews created AT/AFTER this ISO-8601
# timestamp, so legacy 1-5 ratings (a former "5" would now read as a detractor)
# never poison the NPS. OPTIONAL — defaults to the 0-10 deploy date
# (2026-05-27T00:00:00.000Z). Override only for staging back-tests / a future
# re-baseline. Invalid values degrade to the default (logged, never fatal).
NPS_SCALE_EPOCH=
