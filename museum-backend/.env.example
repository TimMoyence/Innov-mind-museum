# ! Musaium backend - staging/production (.env.example)
# === General ===
NODE_ENV=production
ENV=production
PORT=3000
TRUST_PROXY=true
APP_VERSION=1.0.0
TTS_ENABLED=true

# ═══════════════════════════════════════════════ 
# Web Search — Multi-Provider Fallback Chain
# ═══════════════════════════════════════════════ 
FEATURE_FLAG_WEB_SEARCH=true
 
# Provider 1: Tavily (best quality, 1000 free/month)
TAVILY_API_KEY=
 
# Provider 2: Google Custom Search (100 free/day) 
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=YOUR_CSE_ID_HERE
 
# Provider 3: Brave Search (2000 free/month)
BRAVE_SEARCH_API_KEY=
 
# Provider 4: SearXNG (free, unlimited, public instances)
SEARXNG_INSTANCES=https://search.bus-hit.me,https://searx.be,https://search.ononoki.org
 
# Provider 5: DuckDuckGo — no key needed, always available 
 
# Shared config
WEB_SEARCH_TIMEOUT_MS=3000 
WEB_SEARCH_CACHE_TTL_SECONDS=3600 
WEB_SEARCH_MAX_RESULTS=5
 
# ═══════════════════════════════════════════════ 
# Knowledge Extraction Pipeline (background)
# ═══════════════════════════════════════════════ 
FEATURE_FLAG_KNOWLEDGE_EXTRACTION=true


# ── AI Guardrails V2 (P11) ──
GUARDRAILS_V2_CANDIDATE=llm-guard
GUARDRAILS_V2_LLM_GUARD_URL=http://llm-guard:8081
GUARDRAILS_V2_TIMEOUT_MS=500
GUARDRAILS_V2_OBSERVE_ONLY=false
 
# BullMQ Queue 
EXTRACTION_QUEUE_CONCURRENCY=2
EXTRACTION_QUEUE_RATE_LIMIT=60

# Scraper
EXTRACTION_SCRAPE_TIMEOUT_MS=5000
EXTRACTION_CONTENT_MAX_BYTES=51200
EXTRACTION_REFETCH_AFTER_DAYS=7 
 
# LLM Classifier (via LangChain)
EXTRACTION_LLM_MODEL=gpt-4o-mini 
EXTRACTION_CONFIDENCE_THRESHOLD=0.7 
EXTRACTION_REVIEW_THRESHOLD=0.4

# === Network ===
CORS_ORIGINS=https://musaium.com,https://www.musaium.com,https://musaium.fr,https://www.musaium.fr,https://museum.asilidesign.fr
JSON_BODY_LIMIT=5mb
REQUEST_TIMEOUT_MS=20000

# === Database ===
PGDATABASE=museumAI
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MAX=20
DB_SYNCHRONIZE=false
DB_SSL=false

# Social sign-in (Apple + Google)
APPLE_CLIENT_ID=com.musaium.mobile
GOOGLE_OAUTH_CLIENT_ID=498339023976-bjbain2ir2t9q4pu9lsmmk8ni7t96dd7.apps.googleusercontent.com
GOOGLE_OAUTH_WEB_CLIENT_ID=498339023976-bjbain2ir2t9q4pu9lsmmk8ni7t96dd7.apps.googleusercontent.com
GOOGLE_OAUTH_WEB_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://musaium.com/api/auth/google/callback
# === Auth ===
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
MEDIA_SIGNING_SECRET=

# === LLM ===
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_MS=15000
LLM_TIMEOUT_SUMMARY_MS=8000
LLM_TOTAL_BUDGET_MS=25000
LLM_RETRIES=1
LLM_RETRY_BASE_DELAY_MS=250
LLM_MAX_CONCURRENT=5
LLM_MAX_HISTORY_MESSAGES=12
LLM_MAX_TEXT_LENGTH=2000
LLM_MAX_IMAGE_BYTES=3145728
LLM_MAX_AUDIO_BYTES=12582912
LLM_INCLUDE_DIAGNOSTICS=false
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# === Storage ===
OBJECT_STORAGE_DRIVER=local
LOCAL_UPLOADS_DIR=/app/tmp/uploads
S3_SIGNED_URL_TTL_SECONDS=900

# === Rate Limiting ===
RATE_LIMIT_IP=120
RATE_LIMIT_SESSION=60
RATE_LIMIT_WINDOW_MS=60000

# === Upload ===
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/wav,audio/x-wav,audio/webm,audio/ogg,audio/aac

# === Observability ===
SENTRY_DSN=https://5e99435b44776cd076dd3758f4811e02@o4511082055860224.ingest.de.sentry.io/4511082072965200
SENTRY_TRACES_SAMPLE_RATE=0.1

# FEATURE FLAG 
FEATURE_FLAG_STREAMING=true
FEATURE_FLAG_USER_MEMORY=true
FEATURE_FLAG_MULTI_TENANCY=true
FEATURE_FLAG_VOICE_MODE=true
# Guardrail OCR (pas encore mature)
FEATURE_FLAG_OCR_GUARD=false 
# sauf si API publique | Auth par clé API pour partenaires
FEATURE_FLAG_API_KEYS=false 

# Overpass API cache (museum search — optional)
OVERPASS_CACHE_TTL_SECONDS=86400 

# === Cache (Redis) ===
CACHE_ENABLED=true
REDIS_URL=
CACHE_SESSION_TTL_SECONDS=3600
CACHE_LIST_TTL_SECONDS=300
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === Email ===
BREVO_API_KEY=
SMTP_BREVO=

# === FORGOT PASSWORD ===
FRONTEND_URL=https://musaium.com

JWT_ACCESS_SECRET=
MFA_ENCRYPTION_KEY=
MFA_SESSION_TOKEN_SECRET=
CSRF_SECRET=

# ═══════════════════════════════════════════════ 
# TELEMETRIE 
# ═══════════════════════════════════════════════

# GRAPHANA
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=https://musaium.fr/grafana

# TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=