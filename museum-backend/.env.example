# Deprecated convenience template.
# Use environment-specific templates instead:
#   cp .env.local.example .env        # local dev machine
#   cp .env.staging.example .env      # preprod / staging server
#   cp .env.production.example .env   # production server
#
# This file mirrors local defaults only.

NODE_ENV=development
PORT=3000
TRUST_PROXY=false
APP_VERSION=local-dev
COMMIT_SHA=local
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
JSON_BODY_LIMIT=5mb
REQUEST_TIMEOUT_MS=20000
DB_HOST=localhost
DB_PORT=5433
DB_USER=
DB_PASSWORD=
PGDATABASE=museum_ia
DB_POOL_MAX=20
DB_SYNCHRONIZE=false
JWT_ACCESS_SECRET=replace-with-local-access-secret
JWT_REFRESH_SECRET=replace-with-local-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=180d
MEDIA_SIGNING_SECRET=replace-with-local-media-signing-secret
OBJECT_STORAGE_DRIVER=local
LOCAL_UPLOADS_DIR=tmp/uploads
S3_SIGNED_URL_TTL_SECONDS=900
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LLM_TEMPERATURE=0.3
LLM_PARALLEL_ENABLED=false
LLM_TIMEOUT_MS=15000
LLM_TIMEOUT_SUMMARY_MS=8000
LLM_TIMEOUT_EXPERT_COMPACT_MS=20000
LLM_TOTAL_BUDGET_MS=25000
LLM_RETRIES=1
LLM_RETRY_BASE_DELAY_MS=250
LLM_MAX_CONCURRENT=5
LLM_SECTIONS_MAX_CONCURRENT=2
LLM_MAX_HISTORY_MESSAGES=12
LLM_MAX_TEXT_LENGTH=2000
LLM_MAX_IMAGE_BYTES=3145728
LLM_MAX_AUDIO_BYTES=12582912
LLM_INCLUDE_DIAGNOSTICS=true
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
RATE_LIMIT_IP=120
RATE_LIMIT_SESSION=60
RATE_LIMIT_WINDOW_MS=60000
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/wav,audio/x-wav,audio/webm,audio/ogg,audio/aac
