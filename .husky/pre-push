#!/usr/bin/env bash
# =============================================================================
# Musaium pre-push — NO BYPASS
# =============================================================================
# This hook is mandatory. There is no SKIP_PRE_PUSH escape hatch.
# `git push --no-verify` is forbidden by team policy. Server-side CI mirrors
# every gate below (.github/workflows/sentinel-mirror.yml) so any bypass is
# caught at PR time. See docs/CONTRIBUTING.md § Pre-push hooks (NO BYPASS).
#
# Budget: < 2 minutes typical (shift-left doctrine — 2 min local > 15 min CI rouge).
# Gates (each fails fast via `set -e`):
#   1. Backend tsc          — pnpm lint
#   2. Frontend tsc         — npm run lint
#   3. Web tsc              — pnpm lint
#   4. OpenAPI sync         — backend validate + frontend types check
#   5. Migration revertibility sentinel
#   6. Cache-key parity sentinel (FE/BE)            — auto-skips if test absent
#   7. IDOR matrix smoke sentinel                   — auto-skips if test absent
#   8. Guardrails ratchet sentinel                  — keyword count >= baseline
#   9. as-any ratchet (full repo)                   — count <= baseline
#  10. Sentry-scrubber parity sentinel              — PII redaction divergence guard
#  11. Gitleaks scan on push range
#  12. Contract OpenAPI test (BE)                   — pnpm test:contract:openapi
#  13. Migration down() body non-trivial (BE)       — node check-migration-down.cjs
#  14. ast-grep rules                               — auto-skips if ast-grep absent
#  15. OpenAPI breaking changes vs upstream         — auto-skips if oasdiff absent
#  16. Affected unit tests BE                       — jest --findRelatedTests
#  17. Affected tests FE                            — jest --findRelatedTests
#  18. Affected tests Web                           — vitest run --changed
#  19. Prometheus metric-naming ratchet (BE)         — node scripts/sentinels/metric-naming.mjs
#  20. Roadmap claim resolves (UFR-024)              — node scripts/sentinels/roadmap-claim-resolves.mjs
#  21. ai-tests count ratchet (BE)                   — node scripts/sentinels/ai-tests-count.mjs
#  22. Screen test-coverage sentinel (mobile UFR-021) — node scripts/sentinels/screen-test-coverage.mjs
#
# Git LFS: this hook ALSO runs `git lfs pre-push` so LFS objects (see
# .gitattributes — React.xcframework) upload on push. The LFS step is chained
# HERE (inside the tracked husky hook) instead of letting `git lfs install`
# clobber this file — see scripts/install-git-lfs-hooks.mjs + the
# husky-lfs-integrity sentinel. The marker line below lets that sentinel tell a
# real gate apart from a bare git-lfs clobber wrapper. DO NOT remove the marker.
# husky-lfs-integrity: musaium-gate
# =============================================================================
set -e

# Buffer the ref list git delivers on stdin BEFORE any gate runs, so we can feed
# it to `git lfs pre-push` at the end (stdin is single-pass; the gates below do
# not consume it, but buffering is robust against future gates that might).
lfs_stdin="$(cat)"

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

start_ts=$(date +%s)
gate_ts=0
gate_start() { gate_ts=$(date +%s); echo "[pre-push] ► $1"; }
gate_end()   { echo "[pre-push] ✓ $1 ($(( $(date +%s) - gate_ts ))s)"; }

# ─── Gate 1 — Backend tsc ──────────────────────────────────────────────────
gate_start "Gate 1/10 backend tsc (museum-backend)"
( cd museum-backend && pnpm lint ) || {
  echo "[pre-push] ✗ backend tsc failed"; exit 1;
}
gate_end "Gate 1"

# ─── Gate 2 — Frontend tsc ─────────────────────────────────────────────────
gate_start "Gate 2/10 frontend tsc (museum-frontend)"
( cd museum-frontend && npm run lint ) || {
  echo "[pre-push] ✗ frontend tsc failed"; exit 1;
}
gate_end "Gate 2"

# ─── Gate 3 — Web tsc ──────────────────────────────────────────────────────
gate_start "Gate 3/10 web tsc (museum-web)"
( cd museum-web && pnpm lint ) || {
  echo "[pre-push] ✗ web tsc/ESLint failed"; exit 1;
}
gate_end "Gate 3"

# ─── Gate 4 — OpenAPI sync ─────────────────────────────────────────────────
gate_start "Gate 4/10 OpenAPI sync (BE validate + FE types check)"
node scripts/sentinels/openapi-sync.mjs || exit 1
gate_end "Gate 4"

# ─── Gate 4b — Router↔spec drift (R14) ─────────────────────────────────────
# Cycle B: every mounted Express route MUST be documented in openapi.json.
gate_start "Gate 4b router-spec drift sentinel (BE)"
( cd museum-backend && pnpm run sentinel:router-spec-drift ) || exit 1
gate_end "Gate 4b"

# ─── Gate 5 — Migration revertibility ──────────────────────────────────────
gate_start "Gate 5/10 migration revertibility sentinel"
node scripts/sentinels/migration-revertibility.mjs || exit 1
gate_end "Gate 5"

# ─── Gate 6 — Cache-key parity ─────────────────────────────────────────────
gate_start "Gate 6/10 cache-key parity sentinel"
node scripts/sentinels/cache-key-parity.mjs || exit 1
gate_end "Gate 6"

# ─── Gate 7 — IDOR matrix smoke ────────────────────────────────────────────
gate_start "Gate 7/10 IDOR matrix smoke sentinel"
node scripts/sentinels/idor-smoke.mjs || exit 1
gate_end "Gate 7"

# ─── Gate 8 — Guardrails ratchet ───────────────────────────────────────────
gate_start "Gate 8/10 guardrails ratchet sentinel"
node scripts/sentinels/guardrails-ratchet.mjs || exit 1
gate_end "Gate 8"

# ─── Gate 9 — as-any ratchet (full repo) ───────────────────────────────────
gate_start "Gate 9/10 as-any ratchet (full repo)"
node scripts/sentinels/as-any-ratchet.mjs || exit 1
gate_end "Gate 9"

# ─── Gate 10 — Sentry-scrubber parity ──────────────────────────────────────
gate_start "Gate 10/11 sentry-scrubber parity sentinel"
node scripts/sentinels/sentry-scrubber-parity.mjs || exit 1
gate_end "Gate 10"

# ─── Gate 11 — Gitleaks on push range ──────────────────────────────────────
gate_start "Gate 11/11 gitleaks (push range)"
upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo '')"
if [ -n "$upstream" ]; then
  range="${upstream}..HEAD"
else
  range="HEAD~10..HEAD"
fi
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks detect --redact --no-banner --config .gitleaks.toml \
    --log-opts="${range}" || {
    echo "[pre-push] ✗ gitleaks found a secret in the push range (${range})"
    exit 1
  }
else
  echo "[pre-push] ✗ gitleaks binary not found — install: brew install gitleaks"
  exit 1
fi
gate_end "Gate 11"

# ─── Resolve push range for affected-tests gates ───────────────────────────
upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo '')"
if [ -n "$upstream_ref" ]; then
  push_base="$upstream_ref"
else
  push_base="HEAD~10"
fi
# Files touched in push range — used by affected-tests gates below.
# Exclude deletions (`-d` diff filter is added per-language since exclusions differ).
touched_be=$(git diff --name-only --diff-filter=d "$push_base..HEAD" -- 'museum-backend/src/**/*.ts' 'museum-backend/src/**/*.tsx' 2>/dev/null | grep -vE '\.(d\.ts|test\.ts|test\.tsx)$' | grep -vE '/__tests__/' || true)
touched_fe=$(git diff --name-only --diff-filter=d "$push_base..HEAD" -- 'museum-frontend/**/*.ts' 'museum-frontend/**/*.tsx' 2>/dev/null | grep -vE '\.(d\.ts|test\.ts|test\.tsx)$' | grep -vE '/__tests__/|/shared/api/generated/' || true)
touched_web=$(git diff --name-only --diff-filter=d "$push_base..HEAD" -- 'museum-web/src/**/*.ts' 'museum-web/src/**/*.tsx' 2>/dev/null | grep -vE '\.test\.(ts|tsx)$' | grep -vE '/__tests__/' || true)

# ─── Gate 12 — Contract OpenAPI test (BE) ──────────────────────────────────
gate_start "Gate 12/18 contract OpenAPI test (backend)"
( cd museum-backend && pnpm run test:contract:openapi ) || {
  echo "[pre-push] ✗ contract OpenAPI test failed — handler ↔ spec divergence"; exit 1;
}
gate_end "Gate 12"

# ─── Gate 13 — Migration down() body non-trivial (BE) ──────────────────────
gate_start "Gate 13/18 migration down() body non-trivial (backend)"
( cd museum-backend && node scripts/check-migration-down.cjs ) || {
  echo "[pre-push] ✗ a migration has an empty or throwing down() — auto-rollback would break"; exit 1;
}
gate_end "Gate 13"

# ─── Gate 14 — ast-grep rules ──────────────────────────────────────────────
gate_start "Gate 14/18 ast-grep rules (tools/ast-grep-rules/)"
if command -v ast-grep >/dev/null 2>&1; then
  # Scan all source files against committed rules (rules YAML files declare their own scope)
  ast-grep scan --config sgconfig.yml --error 2>&1 | tee /tmp/ast-grep-output.txt
  if grep -qE '^(error|warning)' /tmp/ast-grep-output.txt; then
    echo "[pre-push] ✗ ast-grep flagged a rule violation — see output above"; exit 1
  fi
else
  echo "[pre-push] ⚠ ast-grep binary not found — install: brew install ast-grep (gate skipped)"
fi
gate_end "Gate 14"

# ─── Gate 15 — OpenAPI breaking changes vs upstream ────────────────────────
gate_start "Gate 15/18 OpenAPI breaking changes vs upstream"
if command -v oasdiff >/dev/null 2>&1; then
  if echo "$touched_be" | grep -q "openapi.json" || git diff --name-only "$push_base..HEAD" 2>/dev/null | grep -q "museum-backend/openapi/openapi.json"; then
    upstream_sha="$(git rev-parse "$push_base" 2>/dev/null || echo '')"
    if [ -n "$upstream_sha" ]; then
      git show "$upstream_sha:museum-backend/openapi/openapi.json" > /tmp/openapi-base.json 2>/dev/null || true
      if [ -s /tmp/openapi-base.json ]; then
        # `.oasdiff/severity-levels.txt` carries the project's POLICY for which
        # breaking-change categories block CI vs warn-only. Each entry documents
        # commit + scope + reason. Downgrades surface as WARN in CI logs ; the
        # reviewer MUST inspect each WARN at PR time. NOT a UFR-020 bypass.
        if [ -f .oasdiff/severity-levels.txt ]; then
          oasdiff breaking /tmp/openapi-base.json museum-backend/openapi/openapi.json --fail-on ERR --severity-levels .oasdiff/severity-levels.txt || {
            echo "[pre-push] ✗ oasdiff detected breaking OpenAPI changes vs $push_base"; exit 1
          }
        else
          oasdiff breaking /tmp/openapi-base.json museum-backend/openapi/openapi.json --fail-on ERR || {
            echo "[pre-push] ✗ oasdiff detected breaking OpenAPI changes vs $push_base"; exit 1
          }
        fi
      fi
    fi
  else
    echo "[pre-push]   (no openapi.json changes in push range — skipped)"
  fi
else
  echo "[pre-push] ⚠ oasdiff binary not found — install: curl -fsSL https://raw.githubusercontent.com/oasdiff/oasdiff/main/install.sh | sh (gate skipped)"
fi
gate_end "Gate 15"

# ─── Gate 16 — Affected unit tests (BE) ────────────────────────────────────
gate_start "Gate 16/18 affected unit tests (backend) — jest --findRelatedTests"
if [ -n "$touched_be" ]; then
  echo "[pre-push]   $(echo "$touched_be" | wc -l | tr -d ' ') BE source file(s) changed — running related tests"
  gate16_log="$(mktemp)"
  # shellcheck disable=SC2086
  # `set +e` is required: with `set -e` (line 31), a non-zero jest exit would
  # short-circuit the script BEFORE flake detection runs. We need to capture
  # status, dump output, then decide flake-vs-real ourselves.
  set +e
  # `--testTimeout=30000` mirrors the historical workaround documented in
  # museum-backend/jest.config.ts:31 — `pnpm test:coverage` used to pass this
  # explicitly to absorb supertest+coverage "socket hang up" and bcrypt-heavy
  # integration tests (password reset, MFA, Docker harness boot). When a
  # central file (env.ts, chat-module.ts) is touched, --findRelatedTests pulls
  # the entire integration graph; the default 5s budget then trips structural
  # slow paths that are not regressions. 30s is generous enough to surface
  # genuine slowdowns without flaking on first-test cold starts.
  ( cd museum-backend && pnpm exec jest --watchman=false --runInBand --passWithNoTests --coverage=false --testTimeout=30000 --selectProjects unit-integration --findRelatedTests $(echo "$touched_be" | sed 's|^museum-backend/||') ) > "$gate16_log" 2>&1
  gate16_status=$?
  set -e
  # NEVER `cat "$gate16_log"` full: ~10MB output causes SIGPIPE when git's
  # read buffer closes mid-write → script killed → flake retry never runs.
  # Print only the actionable summary; the full log stays at "$gate16_log"
  # for debug (preserved on failure, cleaned on success).
  grep -E '^(FAIL|PASS).*\.test\.tsx?' "$gate16_log" | tail -20 || true
  grep -E '^Tests:|^Test Suites:' "$gate16_log" | tail -2 || true
  if [ $gate16_status -ne 0 ]; then
    # Flake detection: route test "socket hang up" is a known runInBand teardown race.
    # Robust against jest timing annotations ("(18.704 s)") and project prefix ("unit-integration").
    # Pattern: extract any "tests/.../*.test.tsx?" path that follows a FAIL marker, dedup.
    failed_suites=$(grep -E '^FAIL ' "$gate16_log" | grep -oE 'tests/[A-Za-z0-9_./-]+\.test\.tsx?' | sort -u)
    if [ -n "$failed_suites" ]; then
      echo "[pre-push]   gate 16 initial fail — retrying failed suites in isolation (flake detection):"
      echo "$failed_suites" | sed 's/^/[pre-push]     - /'
      retry_ok=1
      for suite in $failed_suites; do
        ( cd museum-backend && pnpm exec jest --watchman=false --runInBand --passWithNoTests --coverage=false --testTimeout=30000 --selectProjects unit-integration --testPathPattern="$suite" ) >/dev/null 2>&1 || { retry_ok=0; echo "[pre-push]     ✗ $suite still fails in isolation"; }
      done
      if [ "$retry_ok" = "1" ]; then
        echo "[pre-push]   ✓ all retried suites pass in isolation — confirmed flake, accepting gate 16"
      else
        rm -f "$gate16_log"
        echo "[pre-push] ✗ affected backend tests failed (not a flake — fail reproduces in isolation)"; exit 1;
      fi
    else
      rm -f "$gate16_log"
      echo "[pre-push] ✗ affected backend tests failed"; exit 1;
    fi
  fi
  rm -f "$gate16_log"
else
  echo "[pre-push]   (no BE source files changed in push range — skipped)"
fi
gate_end "Gate 16"

# ─── Gate 17 — Affected tests (FE) ─────────────────────────────────────────
gate_start "Gate 17/18 affected tests (frontend) — jest --findRelatedTests"
if [ -n "$touched_fe" ]; then
  echo "[pre-push]   $(echo "$touched_fe" | wc -l | tr -d ' ') FE source file(s) changed — running related tests"
  # `--forceExit --testTimeout=30000` mirrors Gate 16 (BE). RN tests pass but
  # the React Scheduler MessageChannel (upstream react #26608, unfixed since
  # 2023) keeps the event loop alive → jest hangs post-tests → the hook would
  # otherwise be killed by an external SIGTERM and report a fake failure.
  # Added 2026-05-19 after audit-360-w3 first-push diagnostic.
  # shellcheck disable=SC2086
  ( cd museum-frontend && npx jest --watchman=false --runInBand --forceExit --testTimeout=30000 --findRelatedTests --passWithNoTests --coverage=false $(echo "$touched_fe" | sed 's|^museum-frontend/||') ) || {
    echo "[pre-push] ✗ affected frontend tests failed"; exit 1;
  }
else
  echo "[pre-push]   (no FE source files changed in push range — skipped)"
fi
gate_end "Gate 17"

# ─── Gate 18 — Affected tests (Web) ────────────────────────────────────────
gate_start "Gate 18/18 affected tests (web) — vitest run --changed"
if [ -n "$touched_web" ]; then
  echo "[pre-push]   $(echo "$touched_web" | wc -l | tr -d ' ') web source file(s) changed — running vitest --changed"
  ( cd museum-web && pnpm exec vitest run --changed "$push_base" --passWithNoTests ) || {
    echo "[pre-push] ✗ affected web tests failed"; exit 1;
  }
else
  echo "[pre-push]   (no web source files changed in push range — skipped)"
fi
gate_end "Gate 18"

# ─── Gate 19 — Prometheus metric-naming ratchet (BE) ───────────────────────
# Runs UNCONDITIONALLY: the 44-metric inventory freeze + `musaium_` prefix
# cap=16 apply globally, the sentinel runs in ~1s, and any prom change anywhere
# in the repo can trip the registry (TD-PC-03 audit closure).
gate_start "Gate 19/20 Prometheus metric-naming ratchet (backend)"
( cd museum-backend && node scripts/sentinels/metric-naming.mjs ) || {
  echo "[pre-push] ✗ metric-naming ratchet failed — see docs/observability/METRIC_NAMING_AUDIT.md"; exit 1;
}
gate_end "Gate 19"

# ─── Gate 20 — Roadmap claim resolves (UFR-024) ────────────────────────────
# Born of the 2026-05-20 audit which uncovered 22 falsified P0 claims, items
# never checked at merge, fabricated entries, and 1.5-3x inflation in the
# (now-obsolete) ROADMAP_REMEDIATION satellites. This sentinel scans every
# tracked docs/ROADMAP*.md and fails if any path:line / commit SHA / cross-doc
# / workflow ref does not resolve on disk + in git. Roadmaps are the team
# contract — every claim must be verifiable.
gate_start "Gate 20/21 roadmap claim resolves (UFR-024)"
node scripts/sentinels/roadmap-claim-resolves.mjs || {
  echo "[pre-push] ✗ a roadmap cites an item that does not resolve — fix the ref or remove the claim";
  exit 1;
}
gate_end "Gate 20"

# ─── Gate 21 — ai-tests count ratchet (BE) ─────────────────────────────────
# Locks the floor on `museum-backend/tests/ai/**` it() blocks. The ai-tests
# CI job runs `tests/ai/` in isolation (gated on workflow_dispatch / cron
# because real OpenAI calls cost tokens) — Jest's global coverage threshold
# is unreachable from a 19-test subset by construction, so this count ratchet
# takes over the "lock what these tests do" role for the integration-LLM
# contract (vision, guardrail, conversation context, text generation).
gate_start "Gate 21/21 ai-tests count ratchet (backend)"
( cd museum-backend && node scripts/sentinels/ai-tests-count.mjs ) || {
  echo "[pre-push] ✗ ai-tests count regressed — bump MIN_TOTAL_AI_TESTS deliberately or restore the dropped test(s)";
  exit 1;
}
gate_end "Gate 21"

# ─── Gate 22 — Screen test-coverage (mobile UFR-021) ───────────────────────
# Every new/changed user-facing screen (museum-frontend/app/**, features/**/ui/
# *Screen.tsx) MUST ship with a Maestro flow exercising its happy path, OR carry
# an explicit `// e2e-skip: <reason>` opt-out. The sentinel walks the route/
# screen inventory against .maestro/*.yaml + the grandfather baseline and fails
# fast if a screen is uncovered. Catches the DOB-2026-05-17-class regression
# (component test green, real screen broken) BEFORE it reaches TestFlight.
gate_start "Gate 22/22 screen test-coverage sentinel (mobile)"
# Single-line fail-fast form (mirrors Gates 4/5/6 `node … || exit 1`). The
# UFR-021 remediation hint (add a Maestro flow OR `// e2e-skip:`) is printed by
# the sentinel itself on failure, so a bare `|| exit 1` keeps the gate honest
# without swallowing the sentinel's own diagnostics.
node scripts/sentinels/screen-test-coverage.mjs || exit 1
gate_end "Gate 22"

total=$(( $(date +%s) - start_ts ))
echo ""
echo "[pre-push] ═══════════════════════════════════════════════════"
echo "[pre-push] ✅ All 22 gates passed in ${total}s — push authorized"
echo "[pre-push] ═══════════════════════════════════════════════════"

# ─── Git LFS — upload LFS objects for this push ────────────────────────────
# Runs only AFTER every gate passed (a rejected push must not upload). Feeds the
# buffered ref list back on stdin. Non-fatal if git-lfs is absent so a
# contributor without LFS installed is not blocked (committed LFS objects simply
# won't re-upload — CI mirror still enforces correctness).
if command -v git-lfs >/dev/null 2>&1; then
  printf '%s' "$lfs_stdin" | git lfs pre-push "$@"
else
  echo "[pre-push] ⚠ git-lfs not on PATH — skipping LFS object upload (install git-lfs: https://git-lfs.com)"
fi
