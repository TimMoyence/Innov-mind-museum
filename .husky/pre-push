#!/bin/sh

echo "🔍 Pre-push: type-checking backend..."
cd museum-backend && npx tsc --noEmit
BACKEND_EXIT=$?
cd ..

echo "🔍 Pre-push: type-checking frontend..."
cd museum-frontend && npx tsc --noEmit
FRONTEND_EXIT=$?
cd ..

if [ $BACKEND_EXIT -ne 0 ] || [ $FRONTEND_EXIT -ne 0 ]; then
  echo "❌ Type errors detected — push aborted."
  exit 1
fi

echo "✅ Type-check passed."
