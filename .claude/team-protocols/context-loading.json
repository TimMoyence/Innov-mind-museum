{
  "version": "1.0",
  "description": "Smart Context Loading v2 — filtrage KB par mode et pertinence. Remplace le chargement aveugle des 7 fichiers.",
  "always": {
    "description": "Charge a chaque run, quel que soit le mode.",
    "files": [
      "team-knowledge/autonomy-state.json",
      "team-knowledge/next-run.json"
    ],
    "external": [
      "quality-ratchet.json",
      "Dernier rapport executive summary (team-reports/YYYY-MM-DD.md, section ## Executive Summary uniquement)"
    ]
  },
  "dev_modes": {
    "description": "Charge pour les modes feature, bug, refactor, hotfix.",
    "applies_to": ["feature", "feature-backend", "feature-frontend", "feature-fullstack", "bug", "refactor", "hotfix"],
    "files": [
      {"file": "team-knowledge/error-patterns.json", "filter": "unfixed patterns only (fixVerified: false OR status: open)"},
      {"file": "team-knowledge/prompt-enrichments.json", "filter": "by inject_when matching scope (backend/frontend/web/all)"}
    ]
  },
  "audit_modes": {
    "description": "Charge pour les modes audit, chore, et le FINALIZE.",
    "applies_to": ["audit", "chore"],
    "files": [
      "team-knowledge/velocity-metrics.json",
      "team-knowledge/agent-performance.json",
      "team-knowledge/estimation-accuracy.json",
      "team-knowledge/process-amendments.json"
    ]
  },
  "community_skills": {
    "description": "Skills communautaires charges par mode et scope",
    "rules": [
      {
        "id": "langchain",
        "applies_to": ["feature", "feature-backend", "feature-fullstack", "bug", "refactor"],
        "condition": "scope includes chat module OR LangChain pipeline",
        "skills": ["langchain-fundamentals", "langchain-rag", "langchain-middleware"]
      },
      {
        "id": "backend-patterns",
        "applies_to": ["feature", "feature-backend", "feature-fullstack"],
        "condition": "scope includes Express routes OR TypeORM entities",
        "skills": ["backend-patterns"]
      },
      {
        "id": "sast-always",
        "applies_to": ["feature", "feature-backend", "feature-frontend", "feature-fullstack", "bug", "refactor", "audit"],
        "condition": "always in Phase VERIFIER",
        "skills": ["semgrep", "vulnerability-scanner"]
      },
      {
        "id": "sast-deep",
        "applies_to": ["audit"],
        "condition": "audit mode or security-sensitive feature",
        "skills": ["codeql", "variant-analysis", "pentest-checklist", "security-compliance"]
      },
      {
        "id": "supply-chain",
        "applies_to": ["feature", "feature-backend", "feature-fullstack", "chore"],
        "condition": "package.json or pnpm-lock.yaml modified",
        "skills": ["supply-chain-auditor"]
      },
      {
        "id": "verification",
        "applies_to": ["feature", "feature-backend", "feature-frontend", "feature-fullstack", "bug", "refactor"],
        "condition": "always — discipline skill (obra/superpowers)",
        "skills": ["verification-before-completion"]
      },
      {
        "id": "browser-testing",
        "applies_to": ["feature", "feature-frontend", "feature-fullstack", "mockup"],
        "condition": "museum-web/ files in scope",
        "skills": ["browser-use"]
      }
    ]
  },
  "never_load_raw": {
    "description": "Ces fichiers ne doivent PAS etre charges en entier.",
    "rules": [
      "velocity-metrics.json runs > 20 entries: prune before loading",
      "team-reports/*.md detail sections: only load executive summary",
      "agent-performance.json retired agents: skip retiredAgents array"
    ]
  }
}
