{
  "version": "1.1",
  "description": "Contexte technique partage du monorepo Musaium. Source unique pour les versions et structures.",
  "lastUpdated": "2026-04-17",
  "monorepo": {
    "backend": {
      "dir": "museum-backend/",
      "runtime": "Node.js 22",
      "framework": "Express 5",
      "orm": "TypeORM + PostgreSQL 16",
      "packageManager": "pnpm",
      "llm": "LangChain (OpenAI, Google GenAI, Deepseek)",
      "tests": "Jest (ts-jest)",
      "pathAliases": { "@src/*": "src/*", "@modules/*": "src/modules/*", "@shared/*": "src/shared/*", "@data/*": "src/data/*" },
      "commands": {
        "install": "pnpm install",
        "dev": "pnpm dev",
        "lint": "pnpm lint",
        "test": "pnpm test",
        "testE2E": "pnpm test:e2e",
        "testContract": "pnpm test:contract:openapi",
        "build": "pnpm build",
        "migrate": "pnpm migration:run",
        "migrateRevert": "pnpm migration:revert"
      }
    },
    "frontend": {
      "dir": "museum-frontend/",
      "framework": "React Native 0.83",
      "platform": "Expo 55 (New Architecture default)",
      "routing": "Expo Router v7 (file-based)",
      "packageManager": "npm",
      "tests": "jest-expo (1120 tests, 132 suites)",
      "pathAliases": { "@/*": "./*" },
      "commands": {
        "install": "npm install",
        "dev": "npm run dev",
        "lint": "npm run lint",
        "test": "npm test",
        "generateTypes": "npm run generate:openapi-types",
        "checkTypes": "npm run check:openapi-types"
      }
    },
    "web": {
      "dir": "museum-web/",
      "framework": "Next.js 15 (App Router)",
      "rendering": "Server Components par defaut",
      "i18n": "next-intl",
      "tests": "Vitest (174 tests)",
      "commands": {
        "install": "pnpm install",
        "dev": "pnpm dev",
        "lint": "pnpm lint",
        "test": "pnpm test",
        "build": "pnpm build"
      }
    }
  },
  "knowledgeBase": {
    "preamble": "AVANT de coder, lire: (1) error-patterns.json pour les patterns pertinents a ton scope, (2) prompt-enrichments.json pour les regles PE-* applicables, (3) user-feedback-rules.json pour les regles UFR-* non-negociables, (4) appliquer les patterns connus AVANT de coder.",
    "path": ".claude/team-knowledge/"
  },
  "codeIntelligence": {
    "tool": "GitNexus",
    "version": "1.5.3",
    "indexPath": ".gitnexus/",
    "generatedSkillsPath": ".claude/skills/generated/",
    "protocol": "team-protocols/gitnexus-integration.md",
    "mcpTools": ["query", "context", "impact", "detect_changes", "rename", "cypher"],
    "reindex": "npx gitnexus analyze",
    "note": "Agents DEV doivent consulter gitnexus_impact avant de modifier un symbole existant. Post-commit hook auto-reindexe."
  }
}
