{
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "condition": "tool_input.command =~ /^git commit/",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/count-design-debt.py\" --fail-on-debt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/Tim/Desktop/all/dev/Pro/InnovMind/.claude/hooks/stop-quality-summary.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/Tim/Desktop/all/dev/Pro/InnovMind/.claude/hooks/ratchet-check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/Tim/Desktop/all/dev/Pro/InnovMind/.claude/hooks/ssot-sentinel.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
